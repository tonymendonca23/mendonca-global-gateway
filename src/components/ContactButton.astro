---
// Define the props interface with TypeScript
interface Props {
  text: string;
  href?: string;
  className?: string;
  variant?: "contact" | "signup";
}

// Destructure props with default values
const {
  text = "Contact Us",
  href,
  className = "",
  variant = "contact",
} = Astro.props;

// Determine href based on variant
const buttonHref =
  href || (variant === "signup" ? "/auth/register" : "#contact");

// Base button styles using your custom colors
const baseStyles =
  "inline-flex items-center justify-center rounded-md font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 px-4 py-2 text-base";

// Combine base styles with any custom classes passed in
const buttonClasses = `${baseStyles} ${className}`;
---

<a href={buttonHref} class={buttonClasses}>
  {text}
</a>
