---
interface StatusConfig {
    key: string;
    label: string;
    color: string;
}

interface Props {
    statusConfig: StatusConfig[];
    statusCounts: Record<string, number>;
    totalPackages: number;
}

const { statusConfig, statusCounts, totalPackages } = Astro.props;
---

<div class="status-grid">
    {
        statusConfig.map((s) => {
            const count = statusCounts[s.key] || 0;
            const pct =
                totalPackages > 0
                    ? Math.round((count / totalPackages) * 100)
                    : 0;
            return (
                <div class="status-item">
                    <div class="status-header">
                        <span
                            class="status-dot"
                            style={`background: ${s.color}`}
                        />
                        <span class="status-label">{s.label}</span>
                        <span class="status-count">{count}</span>
                    </div>
                    <div class="status-bar-bg">
                        <div
                            class="status-bar"
                            style={`width: ${pct}%; background: ${s.color}`}
                        />
                    </div>
                </div>
            );
        })
    }
</div>

<style>
    .status-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
    }
    .status-item {
        padding: 0.5rem 0.75rem;
        background: #f8fafc;
        border-radius: 0.5rem;
    }
    .status-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.375rem;
    }
    .status-dot {
        width: 0.625rem;
        height: 0.625rem;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .status-label {
        flex: 1;
        font-size: 0.8125rem;
        color: #475569;
    }
    .status-count {
        font-size: 0.875rem;
        font-weight: 600;
        color: #1e293b;
    }
    .status-bar-bg {
        height: 0.25rem;
        background: #e2e8f0;
        border-radius: 0.125rem;
        overflow: hidden;
    }
    .status-bar {
        height: 100%;
        border-radius: 0.125rem;
        transition: width 0.3s ease;
    }
</style>
