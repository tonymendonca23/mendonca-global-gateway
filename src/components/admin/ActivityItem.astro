---
import { formatDate } from "../../lib/utils";

interface Props {
  trackingNumber: string;
  status: string;
  updatedAt: string | number;
}

const { trackingNumber, status, updatedAt } = Astro.props;

// Different icons and colors based on status
const statusStyles: Record<string, { icon: string; bg: string; text: string }> = {
  registered: {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>`,
    bg: "bg-blue-100",
    text: "text-blue-600",
  },
  at_warehouse: {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21h18M3 7v1a3 3 0 006 0V7m0 1a3 3 0 006 0V7m0 1a3 3 0 006 0V7H3l2-4h14l2 4M5 21V10.87"></path>`,
    bg: "bg-yellow-100",
    text: "text-yellow-600",
  },
  in_transit: {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 18H3a2 2 0 01-2-2V8a2 2 0 012-2h3.93M5 18h14a2 2 0 002-2v-4M5 18v-4m14 4v-4m-4-4l-4-4m0 0L7 8m4-4v12"></path>`,
    bg: "bg-orange-100",
    text: "text-orange-600",
  },
  customs: {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>`,
    bg: "bg-purple-100",
    text: "text-purple-600",
  },
  ready: {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>`,
    bg: "bg-green-100",
    text: "text-green-600",
  },
  picked_up: {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>`,
    bg: "bg-slate-100",
    text: "text-slate-600",
  },
};

const style = statusStyles[status] || statusStyles.registered;
---

<div class="flex items-start gap-3 pb-4 border-b border-slate-100 last:border-0">
  <div class={`w-9 h-9 rounded-lg ${style.bg} flex items-center justify-center flex-shrink-0`}>
    <svg class={`w-5 h-5 ${style.text}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={style.icon} />
  </div>
  <div>
    <p class="text-sm font-medium text-slate-800">{trackingNumber}</p>
    <p class="text-xs text-slate-500 capitalize">{status.replace("_", " ")}</p>
    <p class="text-xs text-slate-400">{formatDate(typeof updatedAt === 'string' ? parseInt(updatedAt) : updatedAt)}</p>
  </div>
</div>
