---
const staff = Astro.locals?.staff || { name: "Admin" };
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/admin", label: "Dashboard", icon: "dashboard" },
  { href: "/admin/packages", label: "Packages", icon: "packages" },
  { href: "/admin/customers", label: "Customers", icon: "customers" },
  { href: "/admin/invoices", label: "Invoices", icon: "invoices" },
  { href: "/admin/reviews", label: "Reviews", icon: "reviews" },
  { href: "/admin/settings", label: "Settings", icon: "settings" },
];

const baseLinkClasses =
  "flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all";

const activeClasses = "bg-white/10 text-white";
const inactiveClasses = "text-slate-300 hover:bg-white/5 hover:text-white";

const isActive = (href: string) => {
  // Only treat "/admin" as active on the exact dashboard route
  if (href === "/admin") {
    return currentPath === "/admin";
  }

  return currentPath === href || currentPath.startsWith(href + "/");
};
---

<div
  id="admin-sidebar-backdrop"
  class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
>
</div>

<aside
  id="admin-sidebar"
  class="w-64 bg-[#1e293b] text-white flex-shrink-0 fixed inset-y-0 left-0 z-40 transform -translate-x-full transition-transform duration-200 md:translate-x-0 !fixed md:h-full"
>
  <div class="flex flex-col h-full p-4">
    <div class="flex items-center gap-3 px-2 py-4 mb-6">
      <a href="/" class="flex items-center gap-3">
        <div
          class="w-10 h-10 bg-white rounded-xl flex items-center justify-center shadow-sm"
        >
          <img
            src="/logo.svg"
            alt="Mendonca Global Gateway Logo"
            class="h-7 w-auto"
          />
        </div>
        <div>
          <span class="text-lg font-bold tracking-tight">MGG Admin</span>
          <p class="text-xs text-slate-400">Dashboard</p>
        </div>
      </a>
    </div>

    <nav class="flex-1 space-y-1">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class={`${baseLinkClasses} ${isActive(item.href) ? activeClasses : inactiveClasses}`}
          >
            {item.icon === "dashboard" && (
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                />
              </svg>
            )}
            {item.icon === "packages" && (
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
                />
              </svg>
            )}
            {item.icon === "customers" && (
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1z"
                />
              </svg>
            )}
            {item.icon === "invoices" && (
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                />
              </svg>
            )}
            {item.icon === "settings" && (
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37"
                />
              </svg>
            )}
            {item.icon === "reviews" && (
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                />
              </svg>
            )}
            <span class="font-medium">{item.label}</span>
          </a>
        ))
      }
    </nav>

    <div class="border-t border-slate-700 pt-4 mt-4">
      <a
        href="/api/admin/auth/logout"
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-slate-400 hover:bg-white/5 hover:text-white transition-all"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 16l4-4m0 0l-4-4m4 4H7"></path>
        </svg>
        <span>Logout</span>
      </a>
    </div>
  </div>
</aside>

<script>
  const sidebar =
    document.getElementById("customer-sidebar") ||
    document.getElementById("admin-sidebar");
  const backdrop =
    document.getElementById("customer-sidebar-backdrop") ||
    document.getElementById("admin-sidebar-backdrop");
  const toggleButtons = document.querySelectorAll(
    "#customer-sidebar-toggle, #admin-sidebar-toggle",
  );
  const mainContent = document.querySelector("main");

  function toggleSidebar() {
    const isHidden =
      (sidebar?.classList.contains("-translate-x-full") &&
        window.innerWidth < 768) ||
      sidebar?.style.transform.includes("-100%");

    if (isHidden) {
      sidebar?.classList.remove("-translate-x-full");
      sidebar?.style.removeProperty("transform");
      mainContent?.style.removeProperty("margin-left");
      backdrop?.classList.remove("hidden");
    } else {
      sidebar?.classList.add("-translate-x-full");
      sidebar?.style.setProperty("transform", "translateX(-100%)", "important");
      mainContent?.style.setProperty("margin-left", "0", "important");
      backdrop?.classList.add("hidden");
    }
  }

  toggleButtons.forEach((btn) => btn.addEventListener("click", toggleSidebar));

  if (backdrop) {
    backdrop.addEventListener("click", () => {
      toggleSidebar();
    });
  }
</script>
