---
interface Props {
  title: string;
  value: string | number;
  subtitle: string;
  subtitleClass?: string;
  icon?: string;
  variant?: "warning" | "success" | "info" | "default";
}

const {
  title,
  value,
  subtitle,
  subtitleClass,
  icon = "chart",
  variant = "default",
} = Astro.props;

const variantClasses = {
  warning: {
    title: "text-orange-600",
    value: "text-orange-800",
    subtitle: "text-orange-600",
    iconBg: "bg-orange-100",
    iconText: "text-orange-600",
  },
  success: {
    title: "text-green-600",
    value: "text-green-800",
    subtitle: "text-green-600",
    iconBg: "bg-green-100",
    iconText: "text-green-600",
  },
  info: {
    title: "text-blue-600",
    value: "text-blue-800",
    subtitle: "text-blue-600",
    iconBg: "bg-blue-100",
    iconText: "text-blue-600",
  },
  default: {
    title: "text-slate-500",
    value: "text-slate-800",
    subtitle: "text-slate-400",
    iconBg: "bg-slate-100",
    iconText: "text-slate-600",
  },
};

const icons: Record<string, string> = {
  chart: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>`,
  users: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>`,
  package: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"></path>`,
  check: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>`,
};

const classes = variantClasses[variant];
---

<div class="bg-white rounded-xl p-5 shadow-sm border border-slate-200">
  <div class="flex items-center justify-between">
    <div>
      <p class={`text-sm ${classes.title}`}>{title}</p>
      <p class={`text-3xl font-bold ${classes.value}`}>{value}</p>
      <p class={`text-sm ${subtitleClass || classes.subtitle}`}>{subtitle}</p>
    </div>
    <div class={`w-12 h-12 rounded-xl ${classes.iconBg} flex items-center justify-center`}>
      <svg class={`w-6 h-6 ${classes.iconText}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={icons[icon] || icons.chart} />
    </div>
  </div>
</div>
