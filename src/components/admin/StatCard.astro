---
interface Props {
    title: string;
    value: string | number;
    gradient: string;
    icon: string;
}

const { title, value, gradient, icon } = Astro.props;
---

<div
    class="bg-white rounded-xl p-5 shadow-sm border border-slate-200 hover:shadow-md transition-all kpi-card"
>
    <div class="flex items-center gap-3 mb-3">
        <div
            class={`w-10 h-10 rounded-lg bg-gradient-to-br ${gradient} flex items-center justify-center`}
        >
            <svg
                class="w-5 h-5 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                set:html={icon}
            />
        </div>
    </div>
    <div class="text-3xl font-bold text-slate-800">{value}</div>
    <div class="text-xs text-slate-500 mt-1 font-medium">{title}</div>
</div>
