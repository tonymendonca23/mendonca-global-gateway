---
interface Props {
    title: string;
    subtitle?: string;
    userName?: string;
}

const { title, subtitle, userName } = Astro.props;
---

<header
    class="bg-white border-b border-slate-200 px-4 md:px-8 py-4 md:py-5"
>
    <div class="flex items-center justify-between gap-4">
        <div class="flex items-center gap-3">
            <button
                id="admin-sidebar-toggle"
                class="inline-flex items-center justify-center h-10 w-10 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50"
                type="button"
                aria-label="Toggle navigation"
            >
                <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
            <div>
                <h1 class="text-2xl font-bold text-slate-800">{title}</h1>
                {
                    subtitle && (
                        <p class="text-sm text-slate-500 mt-0.5">
                            {userName
                                ? `Welcome back, ${userName}! ${subtitle}`
                                : subtitle}
                        </p>
                    )
                }
            </div>
        </div>
        <div class="flex items-center gap-3">
            <slot>
                <a
                    href="/admin/packages/new"
                    class="flex items-center gap-2 px-4 py-2.5 bg-white border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-all font-medium text-sm"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 4v16m8-8H4"></path>
                    </svg>
                    Add Package
                </a>
                <a
                    href="/admin/invoices/new"
                    class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all font-medium text-sm shadow-sm"
                >
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M12 4v16m8-8H4"></path>
                    </svg>
                    Create Invoice
                </a>
            </slot>
        </div>
    </div>
</header>
