---
import BaseLayout from "../../layouts/BaseLayout.astro";
import db from "../../lib/db";

const user = Astro.locals.user!;

// Handle form submissions
let success = false;
let error = "";

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();
  const formType = formData.get("formType")?.toString() || "profile";

  if (formType === "profile") {
    const fullName = formData.get("fullName")?.toString()?.trim();
    const phone = formData.get("phone")?.toString()?.trim();
    const address = formData.get("address")?.toString()?.trim();

    if (!fullName) {
      error = "Full name is required";
    } else {
      try {
        await db.execute({
          sql: `
            UPDATE users 
            SET name = ?, phone = ?, address = ?, updated_at = strftime('%s', 'now')
            WHERE id = ?
          `,
          args: [fullName, phone || null, address || null, user.id],
        });
        success = true;
        // Update local user object for display
        user.name = fullName;
        user.phone = phone || null;
        user.address = address || null;
      } catch (e) {
        error = "Failed to update profile. Please try again.";
      }
    }
  }
}

// Get user stats
const statsResult = await db.execute({
  sql: `
    SELECT 
      COUNT(*) as total_packages,
      SUM(CASE WHEN status = 'ready' THEN 1 ELSE 0 END) as ready_packages,
      SUM(CASE WHEN status IN ('registered', 'at_warehouse', 'in_transit', 'customs') THEN 1 ELSE 0 END) as in_progress
    FROM packages 
    WHERE customer_id = ?
  `,
  args: [user.id],
});
const stats = statsResult.rows[0] as any;

// Get invoice stats
const invoiceStats = await db.execute({
  sql: `
    SELECT 
      COUNT(*) as total_invoices,
      SUM(CASE WHEN status = 'unpaid' THEN 1 ELSE 0 END) as unpaid_invoices,
      SUM(CASE WHEN status = 'unpaid' THEN total_gyd ELSE 0 END) as total_owed
    FROM invoices 
    WHERE customer_id = ?
  `,
  args: [user.id],
});
const invoiceData = invoiceStats.rows[0] as any;
---

<BaseLayout title="Profile">
  <div class="min-h-screen">
    <div
      id="customer-sidebar-backdrop"
      class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
    >
    </div>

    <!-- Sidebar -->
    <aside
      id="customer-sidebar"
      class="w-64 bg-primary text-white flex-shrink-0 fixed inset-y-0 left-0 z-40 transform -translate-x-full transition-transform duration-200 md:translate-x-0 !fixed"
    >
      <div class="p-4">
        <a href="/" class="flex items-center gap-3 mb-8">
          <div
            class="w-9 h-9 bg-white rounded-xl flex items-center justify-center shadow-sm"
          >
            <img
              src="/logo.svg"
              alt="Mendonca Global Gateway Logo"
              class="h-8 w-auto"
            />
          </div>
          <span class="text-lg font-heading font-bold tracking-tight">MGG</span>
        </a>

        <nav class="space-y-1">
          <a
            href="/dashboard"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="4" width="4" height="16" rx="1"></rect>
                <rect x="10" y="9" width="4" height="11" rx="1"></rect>
                <rect x="17" y="13" width="4" height="7" rx="1"></rect>
              </svg>
            </span>
            <span>Dashboard</span>
          </a>
          <a
            href="/dashboard/packages"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 7l9-4 9 4"></path>
                <path d="M4 8h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"></path>
                <path d="M12 3v6"></path>
              </svg>
            </span>
            <span>My Packages</span>
          </a>
          <a
            href="/dashboard/invoices"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M7 3h10l2 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"
                ></path>
                <path d="M9 12h6"></path>
                <path d="M9 16h4"></path>
              </svg>
            </span>
            <span>Invoices</span>
          </a>
          <a
            href="/dashboard/profile"
            class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white/10"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="8" r="3"></circle>
                <path d="M6 19a6 6 0 0 1 12 0"></path>
              </svg>
            </span>
            <span>Profile</span>
          </a>
          <a
            href="/dashboard/comments"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
            </span>
            <span>Comments</span>
          </a>
        </nav>

        <hr class="border-white/20 my-6" />

        <a
          href="/api/auth/logout"
          class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition text-white/70"
        >
          <span class="inline-flex items-center justify-center h-5 w-5">
            <svg
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M16 17l5-5-5-5"></path>
              <path d="M21 12H9"></path>
              <path d="M4 4h7v16H4z"></path>
            </svg>
          </span>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="bg-gray-50 md:ml-64 transition-all duration-300">
      <!-- Header -->
      <header class="bg-white border-b border-gray-200 px-4 md:px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <button
              id="customer-sidebar-toggle"
              type="button"
              class="inline-flex items-center justify-center h-10 w-10 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50"
              aria-label="Toggle navigation"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
            <div>
              <h1 class="text-2xl font-heading font-bold text-primary">
                Profile
              </h1>
              <p class="text-sm text-gray-500">
                Manage your personal details and shipping preferences
              </p>
            </div>
          </div>
        </div>
      </header>

      <div class="px-4 md:px-6 py-4 md:py-6">
        <div class="grid lg:grid-cols-3 gap-8">
          <!-- Left Column (Profile & Form) -->
          <div class="lg:col-span-2 space-y-6">
            <!-- Hero Profile Card -->
            <div
              class="bg-gradient-to-br from-primary-800 to-primary-600 rounded-2xl p-6 md:p-8 text-white shadow-xl relative overflow-hidden"
            >
              <div
                class="absolute -right-10 -top-10 w-48 h-48 bg-white/10 rounded-full blur-2xl"
              >
              </div>
              <div
                class="absolute -bottom-12 -left-12 w-40 h-40 bg-white/10 rounded-full blur-xl"
              >
              </div>

              <div
                class="relative z-10 flex flex-col md:flex-row items-center md:items-start gap-6"
              >
                <!-- Avatar block -->
                <div
                  class="w-24 h-24 bg-white/10 backdrop-blur-sm rounded-full flex items-center justify-center text-4xl font-bold uppercase shadow-inner border border-white/20 text-white flex-shrink-0"
                >
                  {user.name.charAt(0)}
                </div>
                <!-- Details block -->
                <div class="text-center md:text-left flex-1 w-full">
                  <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">
                    {user.name}
                  </h2>
                  <div
                    class="flex flex-col md:flex-row items-center gap-2 md:gap-6 text-primary-100 mb-6 text-sm"
                  >
                    <span class="flex items-center gap-2">
                      <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                        ><path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                        ></path></svg
                      >
                      {user.email}
                    </span>
                    {
                      user.phone && (
                        <span class="flex items-center gap-2">
                          <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            />
                          </svg>
                          {user.phone}
                        </span>
                      )
                    }
                  </div>

                  <div
                    class="grid grid-cols-2 lg:inline-grid md:grid-cols-2 gap-4 md:gap-8 bg-black/20 rounded-xl p-4 w-full lg:w-auto border border-white/10 backdrop-blur-sm"
                  >
                    <div>
                      <p
                        class="text-xs text-primary-200 uppercase tracking-wider mb-1 font-semibold"
                      >
                        Date Joined
                      </p>
                      <p class="font-medium text-white flex items-center gap-2">
                        <svg
                          class="w-4 h-4 text-accent"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                          ><path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                          ></path></svg
                        >
                        {
                          new Date(user.created_at * 1000).toLocaleDateString(
                            "en-US",
                            { month: "long", day: "numeric", year: "numeric" },
                          )
                        }
                      </p>
                    </div>
                    <div>
                      <p
                        class="text-xs text-primary-200 uppercase tracking-wider mb-1 font-semibold"
                      >
                        Customer Code
                      </p>
                      <p class="font-mono font-bold text-accent">
                        {user.customer_code}
                      </p>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Profile Settings Form -->
            <div
              class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden"
            >
              <div class="px-6 py-5 border-b border-slate-200 bg-slate-50/50">
                <h3 class="text-lg font-semibold text-slate-800">
                  Update Personal Details
                </h3>
                <p class="text-sm text-slate-500 mt-1">
                  Keep your contact information up to date.
                </p>
              </div>

              <div class="p-6">
                {
                  success && (
                    <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 flex items-center gap-3">
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      Profile updated successfully
                    </div>
                  )
                }

                {
                  error && (
                    <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6 flex items-center gap-3">
                      <svg
                        class="w-5 h-5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                      </svg>
                      {error}
                    </div>
                  )
                }

                <form method="POST" class="space-y-5">
                  <input type="hidden" name="formType" value="profile" />

                  <div class="grid md:grid-cols-2 gap-5">
                    <div>
                      <label
                        class="block text-sm font-medium text-slate-700 mb-1"
                        >Full Name</label
                      >
                      <input
                        type="text"
                        name="fullName"
                        value={user.name}
                        required
                        class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all"
                      />
                    </div>
                    <div>
                      <label
                        class="block text-sm font-medium text-slate-700 mb-1"
                        >Email Address</label
                      >
                      <input
                        type="email"
                        value={user.email}
                        disabled
                        class="w-full px-4 py-2.5 rounded-lg border border-slate-200 bg-slate-50 text-slate-500 cursor-not-allowed"
                      />
                      <p class="text-xs text-slate-400 mt-1">
                        Email cannot be changed.
                      </p>
                    </div>
                  </div>

                  <div class="grid md:grid-cols-2 gap-5">
                    <div>
                      <label
                        class="block text-sm font-medium text-slate-700 mb-1"
                        >Phone Number</label
                      >
                      <input
                        type="tel"
                        name="phone"
                        value={user.phone || ""}
                        class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400"
                        placeholder="+592 ..."
                      />
                    </div>
                    <div>
                      <label
                        class="block text-sm font-medium text-slate-700 mb-1"
                        >Shipping Address</label
                      >
                      <input
                        type="text"
                        name="address"
                        value={user.address || ""}
                        class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder:text-slate-400"
                        placeholder="123 Main St, Georgetown..."
                      />
                    </div>
                  </div>

                  <div class="pt-4 flex justify-end">
                    <button
                      type="submit"
                      class="px-6 py-2.5 bg-primary text-white font-medium rounded-lg hover:bg-primary-700 focus:ring-4 focus:ring-primary/20 transition-all shadow-sm"
                    >
                      Save Changes
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>

          <!-- Right Column (Stats Sidebar) -->
          <div class="space-y-6 lg:col-span-1">
            <div
              class="bg-white rounded-lg shadow-sm p-6 border border-slate-200"
            >
              <h3
                class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4 flex items-center gap-2"
              >
                <svg
                  class="w-4 h-4 text-slate-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
                  ></path></svg
                >
                Account Stats
              </h3>

              <div class="space-y-4">
                <div class="flex justify-between items-center">
                  <span class="text-gray-600 font-medium">Customer ID</span>
                  <span class="font-mono text-sm text-primary font-bold">
                    {user.customer_code || "Assigned by MGG"}
                  </span>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-600 font-medium">Total Packages</span>
                  <span class="font-bold text-primary"
                    >{stats?.total_packages || 0}</span
                  >
                </div>
                <div class="flex justify-between items-center">
                  <span
                    class="text-gray-600 font-medium flex items-center gap-2"
                  >
                    <span class="w-2 h-2 rounded-full bg-green-500"></span>
                    Ready for Pickup
                  </span>
                  <span class="font-bold text-green-600"
                    >{stats?.ready_packages || 0}</span
                  >
                </div>
                <div class="flex justify-between items-center">
                  <span
                    class="text-gray-600 font-medium flex items-center gap-2"
                  >
                    <span class="w-2 h-2 rounded-full bg-orange-400"></span>
                    In Transit
                  </span>
                  <span class="font-bold text-orange-600"
                    >{stats?.in_progress || 0}</span
                  >
                </div>
              </div>
            </div>

            <div
              class="bg-white rounded-lg shadow-sm p-6 border border-slate-200"
            >
              <h3
                class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-4 flex items-center gap-2"
              >
                <svg
                  class="w-4 h-4 text-slate-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path></svg
                >
                Invoice Summary
              </h3>

              <div class="space-y-4">
                <div class="flex justify-between items-center">
                  <span class="text-gray-600 font-medium">Total Invoices</span>
                  <span class="font-bold text-primary"
                    >{invoiceData?.total_invoices || 0}</span
                  >
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-gray-600 font-medium">Unpaid</span>
                  <span class="font-bold text-red-600"
                    >{invoiceData?.unpaid_invoices || 0}</span
                  >
                </div>
                <div
                  class="flex justify-between items-center bg-red-50 p-3 rounded-lg mt-2 border border-red-100"
                >
                  <span class="text-red-700 font-medium">Amount Owed</span>
                  <span class="font-bold text-red-700"
                    >GYD ${
                      (invoiceData?.total_owed || 0).toLocaleString()
                    }</span
                  >
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  const sidebar =
    document.getElementById("customer-sidebar") ||
    document.getElementById("admin-sidebar");
  const backdrop =
    document.getElementById("customer-sidebar-backdrop") ||
    document.getElementById("admin-sidebar-backdrop");
  const toggleButtons = document.querySelectorAll(
    "#customer-sidebar-toggle, #admin-sidebar-toggle",
  );
  const mainContent = document.querySelector("main");

  function toggleSidebar() {
    const isHidden =
      (sidebar?.classList.contains("-translate-x-full") &&
        window.innerWidth < 768) ||
      sidebar?.style.transform.includes("-100%");

    if (isHidden) {
      sidebar?.classList.remove("-translate-x-full");
      sidebar?.style.removeProperty("transform");
      mainContent?.style.removeProperty("margin-left");
      backdrop?.classList.remove("hidden");
    } else {
      sidebar?.classList.add("-translate-x-full");
      sidebar?.style.setProperty("transform", "translateX(-100%)", "important");
      mainContent?.style.setProperty("margin-left", "0", "important");
      backdrop?.classList.add("hidden");
    }
  }

  toggleButtons.forEach((btn) => btn.addEventListener("click", toggleSidebar));

  if (backdrop) {
    backdrop.addEventListener("click", () => {
      toggleSidebar();
    });
  }
</script>
