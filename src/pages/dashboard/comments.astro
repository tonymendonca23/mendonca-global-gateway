---
import BaseLayout from "../../layouts/BaseLayout.astro";
import db from "../../lib/db";
import { generateId } from "../../lib/utils";

const user = Astro.locals.user!;

// Check for success query parameter (from PRG redirect)
const reviewSuccess = Astro.url.searchParams.get("success") === "true";

let reviewError = "";

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const ratingRaw = formData.get("rating")?.toString();
    const comment = formData.get("comment")?.toString().trim();

    const rating = ratingRaw ? parseInt(ratingRaw, 10) : 0;

    if (!rating || rating < 1 || rating > 5) {
        reviewError = "Please select a rating between 1 and 5 stars.";
    } else if (!comment || comment.length < 10) {
        reviewError = "Please share a short comment (at least 10 characters).";
    } else {
        try {
            await db.execute({
                sql: `
          INSERT INTO comments (id, user_id, rating, comment)
          VALUES (?, ?, ?, ?)
        `,
                args: [generateId(), user.id, rating, comment],
            });
            // Redirect to prevent duplicate submissions on refresh (PRG pattern)
            return Astro.redirect("/dashboard/comments?success=true");
        } catch (e) {
            reviewError = "Failed to submit your review. Please try again.";
        }
    }
}
---

<BaseLayout title="Comments">
    <div class="min-h-screen">
        <div
            id="customer-sidebar-backdrop"
            class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
        >
        </div>

        <aside
            id="customer-sidebar"
            class="w-64 bg-primary text-white flex-shrink-0 fixed inset-y-0 left-0 z-40 transform -translate-x-full transition-transform duration-200 md:translate-x-0 !fixed"
        >
            <div class="p-4">
                <a href="/" class="flex items-center gap-3 mb-8">
                    <div
                        class="w-9 h-9 bg-white rounded-xl flex items-center justify-center shadow-sm"
                    >
                        <img
                            src="/logo.svg"
                            alt="Mendonca Global Gateway Logo"
                            class="h-8 w-auto"
                        />
                    </div>
                    <span class="text-lg font-heading font-bold tracking-tight"
                        >MGG</span
                    >
                </a>

                <nav class="space-y-1">
                    <a
                        href="/dashboard"
                        class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
                    >
                        <span
                            class="inline-flex items-center justify-center h-5 w-5"
                        >
                            <svg
                                class="w-5 h-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <rect x="3" y="4" width="4" height="16" rx="1"
                                ></rect>
                                <rect x="10" y="9" width="4" height="11" rx="1"
                                ></rect>
                                <rect x="17" y="13" width="4" height="7" rx="1"
                                ></rect>
                            </svg>
                        </span>
                        <span>Dashboard</span>
                    </a>
                    <a
                        href="/dashboard/packages"
                        class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
                    >
                        <span
                            class="inline-flex items-center justify-center h-5 w-5"
                        >
                            <svg
                                class="w-5 h-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path d="M3 7l9-4 9 4"></path>
                                <path
                                    d="M4 8h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"
                                ></path>
                                <path d="M12 3v6"></path>
                            </svg>
                        </span>
                        <span>My Packages</span>
                    </a>
          <a
            href="/dashboard/packages/new"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="8"></circle>
                <path d="M12 9v6"></path>
                <path d="M9 12h6"></path>
              </svg>
            </span>
            <span>Register Package</span>
          </a>
                    <a
                        href="/dashboard/invoices"
                        class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
                    >
                        <span
                            class="inline-flex items-center justify-center h-5 w-5"
                        >
                            <svg
                                class="w-5 h-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path
                                    d="M7 3h10l2 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"
                                ></path>
                                <path d="M9 12h6"></path>
                                <path d="M9 16h4"></path>
                            </svg>
                        </span>
                        <span>Invoices</span>
                    </a>
                    <a
                        href="/dashboard/profile"
                        class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
                    >
                        <span
                            class="inline-flex items-center justify-center h-5 w-5"
                        >
                            <svg
                                class="w-5 h-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <circle cx="12" cy="8" r="3"></circle>
                                <path d="M6 19a6 6 0 0 1 12 0"></path>
                            </svg>
                        </span>
                        <span>Profile</span>
                    </a>
                    <a
                        href="/dashboard/comments"
                        class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white/10"
                    >
                        <span
                            class="inline-flex items-center justify-center h-5 w-5"
                        >
                            <svg
                                class="w-5 h-5"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <path
                                    d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                ></path>
                            </svg>
                        </span>
                        <span>Comments</span>
                    </a>
                </nav>

                <hr class="border-white/20 my-6" />

                <a
                    href="/api/auth/logout"
                    class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition text-white/70"
                >
                    <span
                        class="inline-flex items-center justify-center h-5 w-5"
                    >
                        <svg
                            class="w-5 h-5"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                        >
                            <path d="M16 17l5-5-5-5"></path>
                            <path d="M21 12H9"></path>
                            <path d="M4 4h7v16H4z"></path>
                        </svg>
                    </span>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <main class="bg-gray-50 md:ml-64 transition-all duration-300">
            <header class="bg-white border-b border-gray-200 px-4 md:px-6 py-4">
                <div class="flex items-center justify-between gap-4">
                    <div class="flex items-center gap-3">
                        <button
                            id="customer-sidebar-toggle"
                            type="button"
                            class="inline-flex items-center justify-center h-10 w-10 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50"
                            aria-label="Toggle navigation"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 6h16M4 12h16M4 18h16"></path>
                            </svg>
                        </button>
                        <div>
                            <h1
                                class="text-2xl font-heading font-bold text-primary"
                            >
                                Share Your Experience
                            </h1>
                            <p class="text-sm text-gray-500">
                                Leave a review about your Mendonca Global
                                Gateway experience.
                            </p>
                        </div>
                    </div>
                </div>
            </header>

            <div class="px-4 md:px-6 py-4 md:py-6 flex justify-center">
                <div class="w-full max-w-xl">
                    <div class="bg-white rounded-lg shadow-sm p-6">
                        <h2 class="text-lg font-semibold text-gray-900 mb-2">
                            Share Your Experience
                        </h2>
                        <p class="text-sm text-gray-500 mb-4">
                            Your feedback helps us improve and may be featured
                            (once approved) on our website.
                        </p>

                        {
                            reviewSuccess && (
                                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-4">
                                    ✓ Thanks for your review! It will appear
                                    once approved.
                                </div>
                            )
                        }

                        {
                            reviewError && (
                                <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-4">
                                    {reviewError}
                                </div>
                            )
                        }

                        <form method="POST" class="space-y-4">
                            <div>
                                <label
                                    class="block text-sm font-medium text-gray-700 mb-1"
                                >
                                    Rating *
                                </label>
                                <select
                                    name="rating"
                                    required
                                    class="input w-full max-w-xs"
                                >
                                    <option value="">Select rating</option>
                                    <option value="5">★★★★★ – Excellent</option>
                                    <option value="4">★★★★☆ – Very good</option>
                                    <option value="3">★★★☆☆ – Good</option>
                                    <option value="2">★★☆☆☆ – Fair</option>
                                    <option value="1">★☆☆☆☆ – Poor</option>
                                </select>
                            </div>

                            <div>
                                <label
                                    class="block text-sm font-medium text-gray-700 mb-1"
                                >
                                    Comment *
                                </label>
                                <textarea
                                    name="comment"
                                    rows="4"
                                    required
                                    class="input"
                                    placeholder="Tell us about your shipping experience, pickup, or support."
                                ></textarea>
                                <p class="text-xs text-gray-400 mt-1">
                                    Please avoid sharing sensitive personal or
                                    payment information in your review.
                                </p>
                            </div>

                            <button type="submit" class="btn-secondary"
                                >Submit Review</button
                            >
                        </form>
                    </div>
                </div>
            </div>
        </main>
    </div>
</BaseLayout>

<script>
    const sidebar =
        document.getElementById("customer-sidebar") ||
        document.getElementById("admin-sidebar");
    const backdrop =
        document.getElementById("customer-sidebar-backdrop") ||
        document.getElementById("admin-sidebar-backdrop");
    const toggleButtons = document.querySelectorAll(
        "#customer-sidebar-toggle, #admin-sidebar-toggle",
    );
    const mainContent = document.querySelector("main");

    function toggleSidebar() {
        const isHidden =
            (sidebar?.classList.contains("-translate-x-full") &&
                window.innerWidth < 768) ||
            sidebar?.style.transform.includes("-100%");

        if (isHidden) {
            sidebar?.classList.remove("-translate-x-full");
            sidebar?.style.removeProperty("transform");
            mainContent?.style.removeProperty("margin-left");
            backdrop?.classList.remove("hidden");
        } else {
            sidebar?.classList.add("-translate-x-full");
            sidebar?.style.setProperty(
                "transform",
                "translateX(-100%)",
                "important",
            );
            mainContent?.style.setProperty("margin-left", "0", "important");
            backdrop?.classList.add("hidden");
        }
    }

    toggleButtons.forEach((btn) =>
        btn.addEventListener("click", toggleSidebar),
    );

    if (backdrop) {
        backdrop.addEventListener("click", () => {
            toggleSidebar();
        });
    }
</script>
