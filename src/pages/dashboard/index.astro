---
import BaseLayout from "../../layouts/BaseLayout.astro";
import db from "../../lib/db";
import { PACKAGE_STATUS_LABELS, formatDate, formatGYD } from "../../lib/utils";

// Get user from middleware
const user = Astro.locals.user!;

// Get user's packages
const packagesResult = await db.execute({
  sql: `SELECT 
          id, mgg_tracking_number, original_tracking_number, store_name, 
          description, weight_lbs, value_usd, status, registered_at, 
          received_at, status_updated_at
        FROM packages 
        WHERE customer_id = ?
        ORDER BY status_updated_at DESC
        LIMIT 10`,
  args: [user.id],
});

// Get outstanding balance
const invoicesResult = await db.execute({
  sql: `SELECT 
          COUNT(*) as count,
          SUM(total_gyd) as total
        FROM invoices 
        WHERE customer_id = ? AND status = 'unpaid'`,
  args: [user.id],
});

const packages = packagesResult.rows;
const outstandingInvoices = invoicesResult.rows[0] as any;
const outstandingBalance = outstandingInvoices?.total || 0;
const outstandingCount = outstandingInvoices?.count || 0;

// Count packages by status
const statusCounts: Record<string, number> = {
  registered: 0,
  at_warehouse: 0,
  in_transit: 0,
  customs: 0,
  ready: 0,
  picked_up: 0,
};

packages.forEach((pkg: any) => {
  if (statusCounts.hasOwnProperty(pkg.status)) {
    statusCounts[pkg.status]++;
  }
});
---

<BaseLayout title="Dashboard">
  <div class="min-h-screen">
    <div
      id="customer-sidebar-backdrop"
      class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
    >
    </div>

    <!-- Sidebar -->
    <aside
      id="customer-sidebar"
      class="w-64 bg-primary text-white flex-shrink-0 fixed inset-y-0 left-0 z-40 transform -translate-x-full transition-transform duration-200 md:translate-x-0 !fixed"
    >
      <div class="p-4">
        <a href="/" class="flex items-center gap-3 mb-8">
          <div
            class="w-9 h-9 bg-white rounded-xl flex items-center justify-center shadow-sm"
          >
            <img
              src="/logo.svg"
              alt="Mendonca Global Gateway Logo"
              class="h-8 w-auto"
            />
          </div>
          <span class="text-lg font-heading font-bold tracking-tight">MGG</span>
        </a>

        <nav class="space-y-1">
          <a
            href="/dashboard"
            class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white/10"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="4" width="4" height="16" rx="1"></rect>
                <rect x="10" y="9" width="4" height="11" rx="1"></rect>
                <rect x="17" y="13" width="4" height="7" rx="1"></rect>
              </svg>
            </span>
            <span>Dashboard</span>
          </a>
          <a
            href="/dashboard/packages"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 7l9-4 9 4"></path>
                <path d="M4 8h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"></path>
                <path d="M12 3v6"></path>
              </svg>
            </span>
            <span>My Packages</span>
          </a>
          <a
            href="/dashboard/packages/new"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="8"></circle>
                <path d="M12 9v6"></path>
                <path d="M9 12h6"></path>
              </svg>
            </span>
            <span>Register Package</span>
          </a>
          <a
            href="/dashboard/invoices"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M7 3h10l2 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"
                ></path>
                <path d="M9 12h6"></path>
                <path d="M9 16h4"></path>
              </svg>
            </span>
            <span>Invoices</span>
          </a>
          <a
            href="/dashboard/profile"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="8" r="3"></circle>
                <path d="M6 19a6 6 0 0 1 12 0"></path>
              </svg>
            </span>
            <span>Profile</span>
          </a>
          <a
            href="/dashboard/comments"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
            </span>
            <span>Comments</span>
          </a>
        </nav>

        <hr class="border-white/20 my-6" />

        <a
          href="/api/auth/logout"
          class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition text-white/70"
        >
          <span class="inline-flex items-center justify-center h-5 w-5">
            <svg
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M16 17l5-5-5-5"></path>
              <path d="M21 12H9"></path>
              <path d="M4 4h7v16H4z"></path>
            </svg>
          </span>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="bg-gray-50 md:ml-64 transition-all duration-300">
      <!-- Header -->
      <header class="bg-white border-b border-gray-200 px-4 md:px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <button
              id="customer-sidebar-toggle"
              type="button"
              class="inline-flex items-center justify-center h-10 w-10 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50"
              aria-label="Toggle navigation"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
            <div>
              <h1 class="text-2xl font-heading font-bold text-primary">
                Dashboard
              </h1>
              <p class="text-sm text-gray-500">
                Welcome back, {user.name}!
              </p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <a href="/dashboard/packages" class="btn-primary">
              View My Packages
            </a>
          </div>
        </div>
      </header>

      <!-- Dashboard Content -->
      <div class="p-4 md:p-6">
        <!-- Outstanding Balance Alert -->
        {
          outstandingBalance > 0 && (
            <div class="card bg-orange-50 border-orange-200 mb-6">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="text-3xl">💰</span>
                  <div>
                    <p class="font-semibold text-orange-800">
                      You have {outstandingCount} unpaid invoice
                      {outstandingCount > 1 ? "s" : ""}
                    </p>
                    <p class="text-orange-600">
                      Outstanding balance:{" "}
                      <strong>{formatGYD(outstandingBalance)}</strong>
                    </p>
                  </div>
                </div>
                <a
                  href="/dashboard/invoices"
                  class="btn-primary bg-orange-600 hover:bg-orange-700"
                >
                  View Invoices
                </a>
              </div>
            </div>
          )
        }

        <!-- Status Cards -->
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
          {
            [
              {
                status: "registered",
                label: "Registered",
                icon: "📝",
                color: "blue",
              },
              {
                status: "at_warehouse",
                label: "At Warehouse",
                icon: "📦",
                color: "yellow",
              },
              {
                status: "in_transit",
                label: "In Transit",
                icon: "✈️",
                color: "orange",
              },
              {
                status: "customs",
                label: "Customs",
                icon: "📋",
                color: "purple",
              },
              { status: "ready", label: "Ready", icon: "✅", color: "green" },
              {
                status: "picked_up",
                label: "Picked Up",
                icon: "📦",
                color: "gray",
              },
            ].map((item) => (
              <div class="card text-center">
                <div class="text-3xl mb-2">{item.icon}</div>
                <div class="text-2xl font-bold text-primary">
                  {statusCounts[item.status] || 0}
                </div>
                <div class="mt-2 text-sm font-semibold text-gray-700">
                  {item.label}
                </div>
              </div>
            ))
          }
        </div>

        <!-- Recent Packages -->
        <div class="card">
          <div class="flex items-center justify-between mb-6">
            <h2 class="text-lg font-heading font-semibold text-primary">
              Recent Packages
            </h2>
            <a
              href="/dashboard/packages"
              class="text-sm text-accent hover:underline">View all →</a
            >
          </div>

          {
            packages.length === 0 ? (
              <div class="text-center py-12">
                <div class="text-5xl mb-4">📦</div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">
                  No packages yet
                </h3>
                <p class="text-gray-600 mb-4">
                  Your packages will appear here once the MGG team registers
                  them for you.
                </p>
                <a href="/dashboard/packages" class="btn-primary">
                  View My Packages
                </a>
              </div>
            ) : (
              <div class="overflow-x-auto">
                <table class="w-full">
                  <thead>
                    <tr class="text-left text-sm text-gray-500 border-b border-gray-200">
                      <th class="pb-3 font-medium">Tracking #</th>
                      <th class="pb-3 font-medium">Store</th>
                      <th class="pb-3 font-medium">Description</th>
                      <th class="pb-3 font-medium">Status</th>
                      <th class="pb-3 font-medium">Updated</th>
                    </tr>
                  </thead>
                  <tbody class="text-sm">
                    {packages.map((pkg: any) => {
                      const statusInfo =
                        PACKAGE_STATUS_LABELS[
                          pkg.status as keyof typeof PACKAGE_STATUS_LABELS
                        ];
                      return (
                        <tr class="border-b border-gray-100 hover:bg-gray-50">
                          <td class="py-3 font-mono text-primary font-medium">
                            {pkg.original_tracking_number || "N/A"}
                          </td>
                          <td class="py-3">{pkg.store_name || "-"}</td>
                          <td class="py-3">{pkg.description || "-"}</td>
                          <td class="py-3">
                            <span
                              class={`inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold
                                  ${
                                    pkg.status === "ready"
                                      ? "bg-green-100 text-green-700 border border-green-200"
                                      : pkg.status === "picked_up"
                                        ? "bg-gray-100 text-gray-700 border border-gray-200"
                                        : pkg.status === "registered"
                                          ? "bg-blue-100 text-blue-700 border border-blue-200"
                                          : pkg.status === "in_transit"
                                            ? "bg-orange-100 text-orange-700 border border-orange-200"
                                            : pkg.status === "customs"
                                              ? "bg-purple-100 text-purple-700 border border-purple-200"
                                              : pkg.status === "at_warehouse"
                                                ? "bg-yellow-100 text-yellow-800 border border-yellow-200"
                                                : "bg-slate-100 text-slate-800 border border-slate-200"
                                  }`}
                            >
                              {statusInfo?.icon}{" "}
                              {statusInfo?.label || pkg.status}
                            </span>
                          </td>
                          <td class="py-3 text-gray-500">
                            {formatDate(pkg.status_updated_at)}
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            )
          }
        </div>

        <!-- US Warehouse Address -->
        <div class="card mt-6">
          <h2 class="text-lg font-heading font-semibold text-primary mb-4">
            Your US Warehouse Address
          </h2>
          <div
            class="bg-gray-50 rounded-lg p-4 font-mono text-sm whitespace-pre-line"
          >
            {
              user.us_warehouse_address ||
                "Address will be generated after first login"
            }
          </div>
          <p class="text-sm text-gray-500 mt-3">
            Use this address when shopping online from US stores. We'll receive
            your packages and ship them to Guyana.
          </p>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  const sidebar =
    document.getElementById("customer-sidebar") ||
    document.getElementById("admin-sidebar");
  const backdrop =
    document.getElementById("customer-sidebar-backdrop") ||
    document.getElementById("admin-sidebar-backdrop");
  const toggleButtons = document.querySelectorAll(
    "#customer-sidebar-toggle, #admin-sidebar-toggle",
  );
  const mainContent = document.querySelector("main");

  function toggleSidebar() {
    const isHidden =
      (sidebar?.classList.contains("-translate-x-full") &&
        window.innerWidth < 768) ||
      sidebar?.style.transform.includes("-100%");

    if (isHidden) {
      sidebar?.classList.remove("-translate-x-full");
      sidebar?.style.removeProperty("transform");
      mainContent?.style.removeProperty("margin-left");
      backdrop?.classList.remove("hidden");
    } else {
      sidebar?.classList.add("-translate-x-full");
      sidebar?.style.setProperty("transform", "translateX(-100%)", "important");
      mainContent?.style.setProperty("margin-left", "0", "important");
      backdrop?.classList.add("hidden");
    }
  }

  toggleButtons.forEach((btn) => btn.addEventListener("click", toggleSidebar));

  if (backdrop) {
    backdrop.addEventListener("click", () => {
      toggleSidebar();
    });
  }
</script>
