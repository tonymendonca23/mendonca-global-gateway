---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import db from "../../../lib/db";
import {
  formatDate,
  formatGYD,
  formatUSD,
  getEnvContactNumbers,
} from "../../../lib/utils";

const user = Astro.locals.user!;

// Get all invoices
const invoicesResult = await db.execute({
  sql: `SELECT 
          i.id, i.invoice_number, i.total_gyd, i.status, 
          i.issued_at, i.paid_at, i.payment_method,
          COUNT(il.id) as package_count
        FROM invoices i
        LEFT JOIN invoice_line_items il ON i.id = il.invoice_id
        WHERE i.customer_id = ?
        GROUP BY i.id
        ORDER BY i.issued_at DESC`,
  args: [user.id],
});

const invoices = invoicesResult.rows;

// Get outstanding total
const outstandingResult = await db.execute({
  sql: `SELECT SUM(total_gyd) as total FROM invoices WHERE customer_id = ? AND status = 'unpaid'`,
  args: [user.id],
});

const outstandingTotal = (outstandingResult.rows[0] as any)?.total || 0;

// Get settings for MMG number
const settingsResult = await db.execute({
  sql: `SELECT key, value FROM settings WHERE key IN ('mmg_number', 'whatsapp_number', 'exchange_rate')`,
  args: [],
});

const settings: Record<string, string> = {};
settingsResult.rows.forEach((row: any) => {
  settings[row.key] = row.value;
});

const { mmgNumber: envMmg, whatsappNumber: envWhatsapp } =
  getEnvContactNumbers();

const mmgSetting = settings.mmg_number;
const whatsappSetting = settings.whatsapp_number;

const mmgNumber = mmgSetting && !mmgSetting.includes("X") ? mmgSetting : envMmg;
const whatsappNumber =
  whatsappSetting && !whatsappSetting.includes("X")
    ? whatsappSetting
    : envWhatsapp;
---

<BaseLayout title="Invoices">
  <div class="min-h-screen">
    <div
      id="customer-sidebar-backdrop"
      class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
    >
    </div>

    <!-- Sidebar -->
    <aside
      id="customer-sidebar"
      class="w-64 bg-primary text-white flex-shrink-0 fixed inset-y-0 left-0 z-40 transform -translate-x-full transition-transform duration-200 md:translate-x-0"
    >
      <div class="p-4">
        <a href="/" class="flex items-center gap-3 mb-8">
          <div
            class="w-9 h-9 bg-white rounded-xl flex items-center justify-center shadow-sm"
          >
            <img
              src="/logo.svg"
              alt="Mendonca Global Gateway Logo"
              class="h-8 w-auto"
            />
          </div>
          <span class="text-lg font-heading font-bold tracking-tight">MGG</span>
        </a>

        <nav class="space-y-1">
          <a
            href="/dashboard"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="4" width="4" height="16" rx="1"></rect>
                <rect x="10" y="9" width="4" height="11" rx="1"></rect>
                <rect x="17" y="13" width="4" height="7" rx="1"></rect>
              </svg>
            </span>
            <span>Dashboard</span>
          </a>
          <a
            href="/dashboard/packages"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 7l9-4 9 4"></path>
                <path d="M4 8h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"></path>
                <path d="M12 3v6"></path>
              </svg>
            </span>
            <span>My Packages</span>
          </a>
          <a
            href="/dashboard/invoices"
            class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white/10"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M7 3h10l2 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"
                ></path>
                <path d="M9 12h6"></path>
                <path d="M9 16h4"></path>
              </svg>
            </span>
            <span>Invoices</span>
          </a>
          <a
            href="/dashboard/profile"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="8" r="3"></circle>
                <path d="M6 19a6 6 0 0 1 12 0"></path>
              </svg>
            </span>
            <span>Profile</span>
          </a>
          <a
            href="/dashboard/comments"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
            </span>
            <span>Comments</span>
          </a>
        </nav>

        <hr class="border-white/20 my-6" />

        <a
          href="/api/auth/logout"
          class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition text-white/70"
        >
          <span class="inline-flex items-center justify-center h-5 w-5">
            <svg
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M16 17l5-5-5-5"></path>
              <path d="M21 12H9"></path>
              <path d="M4 4h7v16H4z"></path>
            </svg>
          </span>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="bg-gray-50 md:ml-64 transition-all duration-300">
      <!-- Header -->
      <header class="bg-white border-b border-gray-200 px-4 md:px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <button
              id="customer-sidebar-toggle"
              type="button"
              class="inline-flex items-center justify-center h-10 w-10 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50"
              aria-label="Toggle navigation"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
            <div>
              <h1 class="text-2xl font-heading font-bold text-primary">
                Invoices
              </h1>
              <p class="text-sm text-gray-500">View and pay your invoices</p>
            </div>
          </div>
        </div>
      </header>

      <!-- Content -->
      <div class="p-4 md:p-6">
        <!-- Outstanding Balance -->
        {
          outstandingTotal > 0 && (
            <div class="card bg-orange-50 border-orange-200 mb-6">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-4">
                  <div class="text-4xl">💰</div>
                  <div>
                    <p class="text-sm text-orange-600">Outstanding Balance</p>
                    <p class="text-3xl font-bold text-orange-800">
                      {formatGYD(outstandingTotal)}
                    </p>
                  </div>
                </div>
                <div class="text-right text-sm text-orange-700">
                  <p class="mb-1 font-medium">MMG Number</p>
                  <p class="font-mono text-lg select-all">{mmgNumber}</p>
                  <p class="text-xs text-orange-600 mt-1">
                    Tap and hold to copy this number in the MMG app.
                  </p>
                </div>
              </div>
            </div>
          )
        }

        <!-- Invoices List -->
        <div class="card">
          <h2 class="text-lg font-heading font-semibold text-primary mb-6">
            All Invoices
          </h2>

          {
            invoices.length === 0 ? (
              <div class="text-center py-12">
                <div class="text-5xl mb-4">🧾</div>
                <h3 class="text-lg font-semibold text-gray-900 mb-2">
                  No invoices yet
                </h3>
                <p class="text-gray-600">
                  Invoices will appear here when your packages are ready for
                  pickup.
                </p>
              </div>
            ) : (
              <div class="overflow-x-auto">
                <table class="w-full">
                  <thead>
                    <tr class="text-left text-sm text-gray-500 border-b border-gray-200">
                      <th class="pb-3 font-medium">Invoice #</th>
                      <th class="pb-3 font-medium">Packages</th>
                      <th class="pb-3 font-medium">Amount</th>
                      <th class="pb-3 font-medium">Issued</th>
                      <th class="pb-3 font-medium">Status</th>
                      <th class="pb-3 font-medium" />
                    </tr>
                  </thead>
                  <tbody class="text-sm">
                    {invoices.map((invoice: any) => (
                      <tr class="border-b border-gray-100 hover:bg-gray-50">
                        <td class="py-4 font-mono text-primary font-medium">
                          {invoice.invoice_number}
                        </td>
                        <td class="py-4">
                          {invoice.package_count} package
                          {invoice.package_count > 1 ? "s" : ""}
                        </td>
                        <td class="py-4 font-semibold">
                          {formatGYD(invoice.total_gyd)}
                        </td>
                        <td class="py-4 text-gray-500">
                          {formatDate(invoice.issued_at)}
                        </td>
                        <td class="py-4">
                          {invoice.status === "paid" ? (
                            <span class="badge badge-green">✓ Paid</span>
                          ) : invoice.status === "voided" ? (
                            <span class="badge badge-gray">Voided</span>
                          ) : (
                            <span class="badge badge-orange">Unpaid</span>
                          )}
                        </td>
                        <td class="py-4 text-right">
                          <a
                            href={`/dashboard/invoices/${invoice.id}`}
                            class="text-accent hover:underline"
                          >
                            View Details
                          </a>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )
          }
        </div>

        <!-- Payment Info -->
        <div class="card mt-6">
          <h3 class="font-semibold text-primary mb-4">💳 Payment Methods</h3>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="bg-gray-50 rounded-lg p-4">
              <h4 class="font-medium mb-2">MMG (Mobile Money Guyana)</h4>
              <p class="text-gray-600 text-sm mb-3">
                Send your invoice total to this MMG number. Be sure to include
                your name or customer ID in the reference.
              </p>
              <p class="font-mono text-lg select-all">{mmgNumber}</p>
            </div>
            <div class="bg-gray-50 rounded-lg p-4">
              <h4 class="font-medium mb-2">Cash at Office</h4>
              <p class="text-gray-600 text-sm mb-3">
                Visit our office to pay in cash when picking up your packages.
              </p>
              <p class="text-sm text-gray-500">📍 Georgetown | Mabaruma</p>
            </div>
          </div>
        </div>

        <!-- WhatsApp Help -->
        <div class="card mt-6 bg-green-50 border-green-200">
          <div class="flex items-center gap-4">
            <div class="text-4xl">💬</div>
            <div>
              <p class="font-medium text-green-800">
                Questions about your invoice?
              </p>
              <p class="text-sm text-green-600 mb-2">
                WhatsApp us and we'll help you understand the charges.
              </p>
              <a
                href={`https://wa.me/${whatsappNumber}`}
                class="text-sm text-green-700 hover:underline font-medium"
              >
                → WhatsApp Support
              </a>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  const sidebar = document.getElementById("customer-sidebar") || document.getElementById("admin-sidebar");
  const backdrop = document.getElementById("customer-sidebar-backdrop") || document.getElementById("admin-sidebar-backdrop");
  const toggleButtons = document.querySelectorAll("#customer-sidebar-toggle, #admin-sidebar-toggle");
  const mainContent = document.querySelector("main");

  function toggleSidebar() {
    const isHidden = (sidebar?.classList.contains("-translate-x-full") && window.innerWidth < 768) || 
                     sidebar?.style.transform.includes('-100%');
    
    if (isHidden) {
      sidebar?.classList.remove("-translate-x-full");
      sidebar?.style.removeProperty('transform');
      mainContent?.style.removeProperty('margin-left');
      backdrop?.classList.remove("hidden");
    } else {
      sidebar?.classList.add("-translate-x-full");
      sidebar?.style.setProperty('transform', 'translateX(-100%)', 'important');
      mainContent?.style.setProperty('margin-left', '0', 'important');
      backdrop?.classList.add("hidden");
    }
  }

  toggleButtons.forEach(btn => btn.addEventListener("click", toggleSidebar));

  if (backdrop) {
    backdrop.addEventListener("click", () => {
      toggleSidebar();
    });
  }
</script>
