---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { STORE_OPTIONS } from "../../../lib/utils";

const user = Astro.locals.user!;
---

<BaseLayout title="Register Package">
  <div class="min-h-screen">
    <div
      id="customer-sidebar-backdrop"
      class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
    >
    </div>

    <!-- Sidebar -->
    <aside
      id="customer-sidebar"
      class="w-64 bg-primary text-white flex-shrink-0 fixed inset-y-0 left-0 z-40 transform -translate-x-full transition-transform duration-200 md:translate-x-0 !fixed"
    >
      <div class="p-4">
        <a href="/" class="flex items-center gap-3 mb-8">
          <div
            class="w-9 h-9 bg-white/10 rounded-lg flex items-center justify-center"
          >
            <svg
              class="w-5 h-5 text-white"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="3" y="7" width="13" height="10" rx="2" ry="2"></rect>
              <path d="M16 11h3l2 3v3h-5"></path>
              <circle cx="7.5" cy="18" r="1.5"></circle>
              <circle cx="18.5" cy="18" r="1.5"></circle>
            </svg>
          </div>
          <span class="text-lg font-heading font-bold tracking-tight">MGG</span>
        </a>

        <nav class="space-y-1">
          <a
            href="/dashboard"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="3" y="4" width="4" height="16" rx="1"></rect>
                <rect x="10" y="9" width="4" height="11" rx="1"></rect>
                <rect x="17" y="13" width="4" height="7" rx="1"></rect>
              </svg>
            </span>
            <span>Dashboard</span>
          </a>
          <a
            href="/dashboard/packages"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M3 7l9-4 9 4"></path>
                <path d="M4 8h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"></path>
                <path d="M12 3v6"></path>
              </svg>
            </span>
            <span>My Packages</span>
          </a>
          <a
            href="/dashboard/packages/new"
            class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white/10"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="12" r="8"></circle>
                <path d="M12 9v6"></path>
                <path d="M9 12h6"></path>
              </svg>
            </span>
            <span>Register Package</span>
          </a>
          <a
            href="/dashboard/invoices"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M7 3h10l2 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"
                ></path>
                <path d="M9 12h6"></path>
                <path d="M9 16h4"></path>
              </svg>
            </span>
            <span>Invoices</span>
          </a>
          <a
            href="/dashboard/profile"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <circle cx="12" cy="8" r="3"></circle>
                <path d="M6 19a6 6 0 0 1 12 0"></path>
              </svg>
            </span>
            <span>Profile</span>
          </a>
          <a
            href="/dashboard/comments"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path>
              </svg>
            </span>
            <span>Comments</span>
          </a>
        </nav>

        <hr class="border-white/20 my-6" />

        <a
          href="/api/auth/logout"
          class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition text-white/70"
        >
          <span class="inline-flex items-center justify-center h-5 w-5">
            <svg
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M16 17l5-5-5-5"></path>
              <path d="M21 12H9"></path>
              <path d="M4 4h7v16H4z"></path>
            </svg>
          </span>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="bg-gray-50 md:ml-64 transition-all duration-300">
      <!-- Header -->
      <header class="bg-white border-b border-gray-200 px-4 md:px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <button
              id="customer-sidebar-toggle"
              type="button"
              class="inline-flex items-center justify-center h-10 w-10 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50"
              aria-label="Toggle navigation"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
            <div>
              <h1 class="text-2xl font-heading font-bold text-primary">
                Register New Package
              </h1>
              <p class="text-sm text-gray-500">
                Package registration is handled by the MGG team
              </p>
            </div>
          </div>
          <a href="/dashboard/packages" class="btn-secondary">
            ← Back to Packages
          </a>
        </div>
      </header>

      <!-- Form -->
      <div class="p-6">
        <div class="max-w-2xl">
          <div class="card">
            <div class="space-y-4">
              <h2 class="text-lg font-semibold text-gray-900">
                Package registration is managed by Mendonça Global Gateway
              </h2>
              <p class="text-sm text-gray-600">
                You no longer need to register packages yourself. Our team will
                add packages to your account when they arrive at the warehouse
                using your tracking number and MMG customer code.
              </p>
              <p class="text-sm text-gray-600">
                If you have a new tracking number you want us to watch, please
                send it to us via WhatsApp or email and we will take care of the
                rest.
              </p>
              <div class="flex flex-wrap gap-3 pt-2">
                <a href="/dashboard/packages" class="btn-primary">
                  View My Packages
                </a>
                <a href="/dashboard" class="btn-secondary">
                  ← Back to Dashboard
                </a>
              </div>
            </div>
          </div>

          <!-- Your US Address -->
          <div class="card mt-6">
            <h3 class="font-semibold text-primary mb-3">
              📍 Your US Warehouse Address
            </h3>
            <div
              class="bg-gray-50 rounded-lg p-4 font-mono text-sm whitespace-pre-line"
            >
              {user.us_warehouse_address}
            </div>
            <p class="text-xs text-gray-500 mt-3">
              Use this address when checking out from US online stores.
            </p>
          </div>

          <!-- WhatsApp Help -->
          <div class="card mt-6 bg-green-50 border-green-200">
            <div class="flex items-center gap-4">
              <div class="text-4xl">💬</div>
              <div>
                <p class="font-medium text-green-800">Need Help?</p>
                <p class="text-sm text-green-600 mb-2">
                  WhatsApp us your tracking number and we'll keep an eye out for
                  your package!
                </p>
                <a
                  href="https://wa.me/592XXXXXXXX"
                  class="text-sm text-green-700 hover:underline font-medium"
                >
                  → WhatsApp Support
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  const sidebar = document.getElementById("customer-sidebar") || document.getElementById("admin-sidebar");
  const backdrop = document.getElementById("customer-sidebar-backdrop") || document.getElementById("admin-sidebar-backdrop");
  const toggleButtons = document.querySelectorAll("#customer-sidebar-toggle, #admin-sidebar-toggle");
  const mainContent = document.querySelector("main");

  function toggleSidebar() {
    const isHidden = (sidebar?.classList.contains("-translate-x-full") && window.innerWidth < 768) || 
                     sidebar?.style.transform.includes('-100%');
    
    if (isHidden) {
      sidebar?.classList.remove("-translate-x-full");
      sidebar?.style.removeProperty('transform');
      mainContent?.style.removeProperty('margin-left');
      backdrop?.classList.remove("hidden");
    } else {
      sidebar?.classList.add("-translate-x-full");
      sidebar?.style.setProperty('transform', 'translateX(-100%)', 'important');
      mainContent?.style.setProperty('margin-left', '0', 'important');
      backdrop?.classList.add("hidden");
    }
  }

  toggleButtons.forEach(btn => btn.addEventListener("click", toggleSidebar));

  if (backdrop) {
    backdrop.addEventListener("click", () => {
      toggleSidebar();
    });
  }
</script>
