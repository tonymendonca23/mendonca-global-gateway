---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import {
  STORE_OPTIONS,
  generateTrackingNumber,
  generateId,
} from "../../../lib/utils";
import db from "../../../lib/db";

const user = Astro.locals.user!;
let error = "";
let success = false;
let createdTrackingNumber = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    const storeName = formData.get("store_name")?.toString().trim();
    const originalTracking = formData
      .get("original_tracking_number")
      ?.toString()
      .trim();
    const description = formData.get("description")?.toString().trim() || null;

    if (!storeName || !originalTracking) {
      error = "Store name and tracking number are required";
    } else {
      // Check for duplicate tracking number globally
      const duplicateCheck = await db.execute({
        sql: `SELECT id FROM packages WHERE original_tracking_number = ?`,
        args: [originalTracking],
      });

      if (duplicateCheck.rows.length > 0) {
        error = "This tracking number has already been registered.";
      } else {
        // Generate unique MGG tracking number
        let mggTrackingNumber = generateTrackingNumber();
        let attempts = 0;
        while (attempts < 10) {
          const check = await db.execute({
            sql: `SELECT id FROM packages WHERE mgg_tracking_number = ?`,
            args: [mggTrackingNumber],
          });
          if (check.rows.length === 0) break;
          mggTrackingNumber = generateTrackingNumber();
          attempts++;
        }

        // Insert into packages with 'registered' status (Pre-alert)
        const packageId = generateId();
        await db.execute({
          sql: `
                        INSERT INTO packages (
                            id, 
                            mgg_tracking_number, 
                            original_tracking_number, 
                            customer_id, 
                            store_name, 
                            description, 
                            status, 
                            registered_at
                        ) VALUES (?, ?, ?, ?, ?, ?, 'registered', unixepoch())
                    `,
          args: [
            packageId,
            mggTrackingNumber,
            originalTracking,
            user.id,
            storeName,
            description,
          ],
        });

        success = true;
        createdTrackingNumber = originalTracking;
      }
    }
  } catch (e) {
    console.error("Error creating expected package", e);
    error = "Failed to register package. Please try again or contact support.";
  }
}
---

<BaseLayout title="Register Package">
  <div class="min-h-screen">
    <div
      id="customer-sidebar-backdrop"
      class="fixed inset-0 bg-black/40 z-30 hidden md:hidden"
    >
    </div>

    <!-- Sidebar -->
    <aside
      id="customer-sidebar"
      class="w-64 bg-primary text-white flex-shrink-0 fixed inset-y-0 left-0 z-40 transform -translate-x-full transition-transform duration-200 md:translate-x-0 !fixed"
    >
      <div class="p-4">
        <a href="/" class="flex items-center gap-3 mb-8">
          <div
            class="w-9 h-9 bg-white rounded-xl flex items-center justify-center shadow-sm"
          >
            <img
              src="/logo.svg"
              alt="Mendonca Global Gateway Logo"
              class="h-8 w-auto"
            />
          </div>
          <span class="text-lg font-heading font-bold tracking-tight">MGG</span>
        </a>

        <nav class="space-y-1">
          <a
            href="/dashboard"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect x="3" y="4" width="4" height="16" rx="1"></rect><rect
                  x="10"
                  y="9"
                  width="4"
                  height="11"
                  rx="1"></rect><rect x="17" y="13" width="4" height="7" rx="1"
                ></rect></svg
              >
            </span>
            <span>Dashboard</span>
          </a>
          <a
            href="/dashboard/packages"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M3 7l9-4 9 4"></path><path
                  d="M4 8h16v9a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8z"></path><path
                  d="M12 3v6"></path></svg
              >
            </span>
            <span>My Packages</span>
          </a>
          <a
            href="/dashboard/packages/new"
            class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white/10"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="8"></circle><path d="M12 9v6"
                ></path><path d="M9 12h6"></path></svg
              >
            </span>
            <span>Register Package</span>
          </a>
          <a
            href="/dashboard/invoices"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M7 3h10l2 3v13a1 1 0 0 1-1 1H6a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1z"
                ></path><path d="M9 12h6"></path><path d="M9 16h4"></path></svg
              >
            </span>
            <span>Invoices</span>
          </a>
          <a
            href="/dashboard/profile"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="8" r="3"></circle><path
                  d="M6 19a6 6 0 0 1 12 0"></path></svg
              >
            </span>
            <span>Profile</span>
          </a>
          <a
            href="/dashboard/comments"
            class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition"
          >
            <span class="inline-flex items-center justify-center h-5 w-5">
              <svg
                class="w-5 h-5"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                ></path></svg
              >
            </span>
            <span>Comments</span>
          </a>
        </nav>

        <hr class="border-white/20 my-6" />

        <a
          href="/api/auth/logout"
          class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 transition text-white/70"
        >
          <span class="inline-flex items-center justify-center h-5 w-5">
            <svg
              class="w-5 h-5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M16 17l5-5-5-5"></path><path d="M21 12H9"></path><path
                d="M4 4h7v16H4z"></path></svg
            >
          </span>
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="bg-gray-50 md:ml-64 transition-all duration-300">
      <!-- Header -->
      <header class="bg-white border-b border-gray-200 px-4 md:px-6 py-4">
        <div class="flex items-center justify-between gap-4">
          <div class="flex items-center gap-3">
            <button
              id="customer-sidebar-toggle"
              type="button"
              class="inline-flex items-center justify-center h-10 w-10 rounded-lg border border-slate-200 text-slate-700 hover:bg-slate-50"
              aria-label="Toggle navigation"
            >
              <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
            <div>
              <h1 class="text-2xl font-heading font-bold text-primary">
                Register Expected Package
              </h1>
              <p class="text-sm text-gray-500">
                Let us know what's coming so we process it faster
              </p>
            </div>
          </div>
          <a href="/dashboard/packages" class="btn-secondary">
            ← Back to Packages
          </a>
        </div>
      </header>

      <!-- Form -->
      <div class="p-4 md:p-6 max-w-2xl mx-auto">
        {
          success ? (
            <div class="bg-white rounded-lg shadow-sm p-8 text-center mt-8 border border-gray-200">
              <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-green-100 text-green-600 mb-6">
                <svg
                  class="w-8 h-8"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
              </div>
              <h3 class="text-xl font-semibold text-gray-900 mb-2">
                Package Successfully Submitted!
              </h3>
              <p class="text-gray-500 mb-6">
                Tracking Number{" "}
                <span class="font-mono font-medium text-gray-900">
                  {createdTrackingNumber}
                </span>{" "}
                is now recorded.
              </p>
              <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="/dashboard/packages" class="btn-primary">
                  View Packages
                </a>
                <a
                  href="/dashboard/packages/new"
                  class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white/10 text-white font-medium transition"
                >
                  Add Another
                </a>
              </div>
            </div>
          ) : (
            <div class="space-y-6 mt-4">
              <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-blue-800 text-sm">
                <p class="font-semibold mb-1 flex items-center gap-2">
                  <span class="text-lg">💡</span> Why pre-register?
                </p>
                <p>
                  Entering your tracking number here connects your package to
                  your account instantly when it hits our US warehouse, avoiding
                  delays.
                </p>
              </div>

              <form
                method="POST"
                class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden"
              >
                <div class="p-6 space-y-6">
                  {error && (
                    <div class="p-4 text-sm text-red-700 bg-red-50 border border-red-200 rounded-lg">
                      {error}
                    </div>
                  )}

                  <div>
                    <label
                      for="store_name"
                      class="block text-sm font-medium text-gray-700 mb-1"
                    >
                      Store / Retailer *
                    </label>
                    <select
                      id="store_name"
                      name="store_name"
                      class="input w-full"
                      required
                    >
                      <option value="">Select a store...</option>
                      {STORE_OPTIONS.map((store) => (
                        <option value={store}>{store}</option>
                      ))}
                      <option value="Other">Other</option>
                    </select>
                  </div>

                  <div>
                    <label
                      for="original_tracking_number"
                      class="block text-sm font-medium text-gray-700 mb-1"
                    >
                      Original Tracking Number *
                    </label>
                    <input
                      type="text"
                      id="original_tracking_number"
                      name="original_tracking_number"
                      required
                      class="input w-full font-mono"
                      placeholder="e.g. TBA1234567890"
                    />
                    <p class="mt-1 text-xs text-gray-500">
                      The carrier tracking number (Amazon, FedEx, USPS, etc.)
                      provided in your shipping email
                    </p>
                  </div>

                  <div>
                    <label
                      for="description"
                      class="block text-sm font-medium text-gray-700 mb-1"
                    >
                      Package Description (Optional)
                    </label>
                    <input
                      type="text"
                      id="description"
                      name="description"
                      class="input w-full"
                      placeholder="e.g. 2 pairs of shoes, gym equipment"
                    />
                  </div>
                </div>

                <div class="bg-gray-50 px-6 py-4 border-t border-gray-100 flex justify-end">
                  <button type="submit" class="btn-primary">
                    Submit Tracking
                  </button>
                </div>
              </form>

              <div class="card mt-8">
                <h3 class="font-semibold text-primary mb-3">
                  📍 Your US Warehouse Address
                </h3>
                <div class="bg-gray-50 rounded-lg p-4 font-mono text-sm whitespace-pre-line">
                  {user.us_warehouse_address}
                </div>
                <p class="text-xs text-gray-500 mt-3">
                  Use this address when checking out from US online stores.
                </p>
              </div>
            </div>
          )
        }
      </div>
    </main>
  </div>
</BaseLayout>

<script>
  const sidebar =
    document.getElementById("customer-sidebar") ||
    document.getElementById("admin-sidebar");
  const backdrop =
    document.getElementById("customer-sidebar-backdrop") ||
    document.getElementById("admin-sidebar-backdrop");
  const toggleButtons = document.querySelectorAll(
    "#customer-sidebar-toggle, #admin-sidebar-toggle",
  );
  const mainContent = document.querySelector("main");

  function toggleSidebar() {
    const isHidden =
      (sidebar?.classList.contains("-translate-x-full") &&
        window.innerWidth < 768) ||
      sidebar?.style.transform.includes("-100%");

    if (isHidden) {
      sidebar?.classList.remove("-translate-x-full");
      sidebar?.style.removeProperty("transform");
      mainContent?.style.removeProperty("margin-left");
      backdrop?.classList.remove("hidden");
    } else {
      sidebar?.classList.add("-translate-x-full");
      sidebar?.style.setProperty("transform", "translateX(-100%)", "important");
      mainContent?.style.setProperty("margin-left", "0", "important");
      backdrop?.classList.add("hidden");
    }
  }

  toggleButtons.forEach((btn) => btn.addEventListener("click", toggleSidebar));

  if (backdrop) {
    backdrop.addEventListener("click", () => {
      toggleSidebar();
    });
  }
</script>
