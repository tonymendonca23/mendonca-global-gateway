---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/ContactForm.astro';
import ContactButton from '../components/ContactButton.astro';
import Footer from '../components/Footer.astro';

// Define headline and subheadline for the About Hero
const heroHeadline = 'More Than Just Shipping.';
const heroSubheadline = 'Building trust through professionalism, transparency, and consistency. Bridging the gap between the USA, Georgetown, and Mabaruma.';

const coreValues = [
  {
    title: "Transparency",
    description: "No guessing games. You know our rate ($2.70 USD/lb) and our exchange rate ($222) before you even ship. We believe in honest business.",
    icon: "search-circle"
  },
  {
    title: "Communication",
    description: "We know the anxiety of waiting for a package. That’s why we require tracking numbers—so we can keep you informed via WhatsApp and email every step of the way.",
    icon: "chat-alt-2"
  },
  {
    title: "Reliability",
    description: "We stick to Air Freight for a reason. Speed and safety are our priorities. We treat every package like it is our own.",
    icon: "shield-check"
  }
];
---

<Layout>
  <Header />

  <main class='pt-20 md:pt-24 bg-white dark:bg-slate-950 transition-colors duration-300'>
    <!-- Hero Section: The Vision -->
    <section class='relative py-20 md:py-32 overflow-hidden bg-gradient-to-br from-gray-50 via-white to-gray-100 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950'>
      <!-- Decorative Elements -->
      <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-[400px] h-[400px] bg-secondary/5 rounded-full blur-3xl pointer-events-none"></div>

      <div class='container mx-auto px-4 md:px-6 relative z-10'>
        <div class='max-w-4xl mx-auto text-center'>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/5 dark:bg-primary/10 text-primary dark:text-primary-light text-sm font-semibold mb-6 border border-primary/10 dark:border-primary/20">
            Our Vision
          </div>
          <h1 class='text-4xl md:text-5xl lg:text-7xl font-bold leading-tight mb-6 text-custom-bg dark:text-white tracking-tight'>
            {heroHeadline}
          </h1>
          <p class='text-xl md:text-2xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-3xl mx-auto font-light'>
            {heroSubheadline}
          </p>
        </div>
      </div>
    </section>

    <!-- OUR STORY -->
    <section class='py-24 bg-white dark:bg-slate-900 transition-colors duration-300'>
      <div class='container mx-auto px-4 md:px-6'>
        <div class='flex flex-col lg:flex-row gap-16 items-center'>
          <div class='lg:w-1/2'>
            <div class='relative group'>
              <div class="absolute inset-0 bg-gradient-to-tr from-primary to-secondary rounded-3xl rotate-3 opacity-10 scale-105 group-hover:rotate-0 transition-transform duration-500"></div>
              <div class="relative overflow-hidden rounded-3xl shadow-2xl border-4 border-white dark:border-slate-800">
                <img 
                  src='/aboutus_1.jpg' 
                  alt='Our Story - Professional Logistics' 
                  class='w-full aspect-[4/3] object-cover transition-transform duration-700 group-hover:scale-110'
                  loading="lazy"
                  decoding="async"
                />
                <div class="absolute inset-0 bg-primary/10 group-hover:bg-transparent transition-colors duration-500"></div>
              </div>
            </div>
          </div>
          <div class='lg:w-1/2 space-y-8'>
            <div class='space-y-4'>
              <h2 class='text-3xl md:text-4xl lg:text-5xl font-bold text-custom-bg dark:text-white tracking-tight leading-tight'>
                Why We Created Mendonca Global Gateway
              </h2>
              <div class="w-20 h-1.5 bg-primary rounded-full"></div>
            </div>
            <div class='space-y-6 text-lg md:text-xl text-gray-600 dark:text-gray-400 leading-relaxed font-light'>
              <p>
                Mendonca Global Gateway was created to make international shipping simpler, clearer, and more reliable for customers in Guyana.
              </p>
              <p>
                In an industry where packages often go missing, fees are hidden, and communication is poor, we chose a different path. We focus on <span class="text-primary font-bold">transparency</span>, <span class="text-primary font-bold">proper communication</span>, and <span class="text-primary font-bold">structured processes</span> so clients always know what to expect—from the moment they shop to the moment we clear customs.
              </p>
              <p class="font-medium text-custom-bg dark:text-white border-l-4 border-secondary pl-6 py-2 italic">
                Our goal is not just to move packages, but to build trust through professionalism and consistency.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- OUR MISSION: Connecting All of Guyana -->
    <section class='py-24 bg-gray-50 dark:bg-slate-950 relative overflow-hidden transition-colors duration-300'>
      <div class='container mx-auto px-4 md:px-6 relative z-10'>
        <div class='max-w-4xl mx-auto text-center mb-20 space-y-4'>
          <h2 class='text-3xl md:text-5xl lg:text-6xl font-bold text-custom-bg dark:text-white tracking-tight'>
            From the Capital to the Hinterland
          </h2>
          <p class='text-xl md:text-2xl text-gray-600 dark:text-gray-400 font-light italic'>
            Our Mission: Connecting All of Guyana
          </p>
          <div class="w-24 h-1 bg-gradient-to-r from-primary to-secondary mx-auto rounded-full mt-8"></div>
        </div>

        <div class='grid lg:grid-cols-2 gap-12 lg:gap-20 items-stretch'>
          <div class='bg-white dark:bg-slate-900 p-8 md:p-16 rounded-[2.5rem] shadow-xl border border-gray-100 dark:border-slate-800 space-y-8 flex flex-col justify-center relative overflow-hidden'>
            <!-- Background Decorative Shape -->
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-secondary/5 rounded-full blur-3xl"></div>
            
            <p class='text-lg md:text-2xl text-gray-600 dark:text-gray-400 leading-relaxed font-light relative z-10'>
              We believe access to the global market shouldn't depend on where you live. While many couriers focus solely on Georgetown, we are committed to serving the wider community.
            </p>
            <p class='text-lg md:text-2xl text-gray-600 dark:text-gray-400 leading-relaxed font-light relative z-10'>
              With our <span class="text-secondary font-bold underline decoration-secondary/30 underline-offset-8">dedicated branch in Mabaruma (Region 1)</span>, we ensure that families and businesses in remote areas have the same fast access to US goods as those in the city. We are the bridge that connects you to the world.
            </p>
          </div>
          <div class='relative group overflow-hidden rounded-[2.5rem] shadow-2xl'>
            <img 
              src='/aboutus-image3.jpg' 
              alt='Region 1: Mabaruma Connection' 
              class='w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110'
              loading="lazy"
              decoding="async"
            />
            <div class='absolute inset-0 bg-gradient-to-t from-custom-bg/90 via-custom-bg/20 to-transparent flex items-end p-10 opacity-90 group-hover:opacity-100 transition-opacity duration-500'>
              <div class='text-white space-y-3 transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500'>
                <div class='inline-block px-4 py-1 bg-primary text-white text-xs font-bold uppercase tracking-[0.2em] rounded-full'>
                  Location Focus
                </div>
                <div class='text-3xl md:text-4xl font-bold tracking-tight'>Region 1: Mabaruma</div>
                <p class="text-white/70 text-sm md:text-base font-light max-w-sm">Bringing the world to the hinterland with speed and reliability.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- OUR CORE VALUES -->
    <section class='py-24 bg-white dark:bg-slate-900 transition-colors duration-300'>
      <div class='container mx-auto px-4 md:px-6'>
        <div class='text-center max-w-3xl mx-auto mb-20 space-y-4'>
          <h2 class='text-3xl md:text-4xl font-bold text-custom-bg dark:text-white tracking-tight'>
            Our Core Values
          </h2>
          <p class='text-xl text-gray-500 dark:text-gray-400 font-light'>
            The principles that guide every package we handle.
          </p>
          <div class="w-20 h-1.5 bg-primary mx-auto rounded-full"></div>
        </div>

        <div class='grid md:grid-cols-3 gap-8'>
          {coreValues.map((value, index) => (
            <div class='group bg-gray-50 dark:bg-slate-800 p-10 rounded-3xl border border-gray-100 dark:border-slate-700 hover:border-primary/30 transition-all duration-300 hover:shadow-2xl hover:-translate-y-2'>
              <div class='w-16 h-16 bg-primary/10 dark:bg-primary/20 rounded-2xl flex items-center justify-center text-primary mb-8 group-hover:bg-primary group-hover:text-white transition-all duration-300'>
                {value.icon === "search-circle" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                  </svg>
                )}
                {value.icon === "chat-alt-2" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8h2a2 2 0 012 2v6a2 2 0 01-2 2h-2v4l-4-4H9a1.994 1.994 0 01-1.414-.586m0 0L11 14h4a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2v4l.586-.586z" />
                  </svg>
                )}
                {value.icon === "shield-check" && (
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                )}
              </div>
              <h3 class='text-2xl font-bold text-custom-bg dark:text-white mb-4'>{value.title}</h3>
              <p class='text-gray-600 dark:text-gray-400 leading-relaxed'>
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FINAL CALL TO ACTION -->
    <section class='py-24 bg-gradient-to-br from-custom-bg to-primary text-white overflow-hidden relative'>
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
      <div class='container mx-auto px-4 md:px-6 relative z-10 text-center space-y-10'>
        <h2 class='text-4xl md:text-6xl font-bold tracking-tight max-w-4xl mx-auto'>
          Experience the Difference.
        </h2>
        <p class='text-xl md:text-2xl text-white/80 max-w-2xl mx-auto font-light leading-relaxed'>
          Stop worrying about your packages. Join the shipping service that puts you first.
        </p>
        <div class='pt-4'>
          <ContactButton 
            text='OPEN YOUR FREE ACCOUNT' 
            href='/#contact' 
            className='bg-white text-custom-bg px-12 py-5 rounded-2xl hover:bg-gray-100 transition-all duration-300 font-bold text-xl shadow-2xl hover:scale-105 transform'
          />
        </div>
      </div>
    </section>

    <!-- Contact Form Section -->
    <ContactForm />
  </main>

  <Footer />
</Layout>
