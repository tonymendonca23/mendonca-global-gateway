---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import DashboardHeader from '../../../components/admin/DashboardHeader.astro';
import db from '../../../lib/db';
import { PACKAGE_STATUS_LABELS, formatDate, formatGYD, formatUSD, getStatusColor } from '../../../lib/utils';

const staff = Astro.locals.staff!;

// Get filter from URL
const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get('status') || '';
const searchQuery = url.searchParams.get('search') || '';
const customerFilter = url.searchParams.get('customer') || '';
const page = parseInt(url.searchParams.get('page') || '1');
const perPage = 20;

// Build query
let countSql = `SELECT COUNT(*) as total FROM packages p`;
let sql = `
  SELECT 
    p.*,
    u.email as customer_email,
    u.name as customer_name
  FROM packages p
  LEFT JOIN users u ON p.customer_id = u.id
`;

const whereClauses: string[] = [];
const args: any[] = [];
const countArgs: any[] = [];

if (customerFilter) {
  whereClauses.push('p.customer_id = ?');
  args.push(customerFilter);
  countArgs.push(customerFilter);
}

if (statusFilter) {
  whereClauses.push('p.status = ?');
  args.push(statusFilter);
  countArgs.push(statusFilter);
}

if (searchQuery) {
  whereClauses.push(`(p.mgg_tracking_number LIKE ? OR p.original_tracking_number LIKE ? OR p.description LIKE ? OR u.email LIKE ? OR u.name LIKE ?)`);
  const searchTerm = `%${searchQuery}%`;
  args.push(searchTerm, searchTerm, searchTerm, searchTerm, searchTerm);
  countArgs.push(searchTerm, searchTerm, searchTerm, searchTerm, searchTerm);
}

if (whereClauses.length > 0) {
  const whereClause = ` WHERE ${whereClauses.join(' AND ')}`;
  sql += whereClause;
  countSql += whereClause;
}

// Get total count
const countResult = await db.execute({ sql: countSql, args: countArgs });
const total = (countResult.rows[0] as any)?.total || 0;
const totalPages = Math.ceil(total / perPage);

// Add pagination
sql += ` ORDER BY p.registered_at DESC LIMIT ? OFFSET ?`;
args.push(perPage, (page - 1) * perPage);

const packagesResult = await db.execute({ sql, args });
const packages = packagesResult.rows;

// Get status counts for tabs
const statusCountsResult = await db.execute({
  sql: `SELECT status, COUNT(*) as count FROM packages ${customerFilter ? 'WHERE customer_id = ?' : ''} GROUP BY status`,
  args: customerFilter ? [customerFilter] : [],
});
const statusCounts: Record<string, number> = { all: total };
statusCountsResult.rows.forEach((row: any) => {
  statusCounts[row.status] = row.count;
});
---

<BaseLayout title="Package Management">
  <div class="min-h-screen">
    <AdminSidebar />

    <!-- Main Content -->
      <main class="md:ml-64 bg-[#f1f5f9] min-h-screen transition-all duration-300">
      <DashboardHeader 
        title="Package Management" 
        subtitle="Manage and track all customer packages"
      >
        <Fragment />
      </DashboardHeader>

      <!-- Content -->
      <div class="p-8">
        <!-- Status Tabs -->
        <div class="flex flex-wrap gap-2 mb-6">
          <a 
            href="?status="
            class={`inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition ${
              !statusFilter ? 'bg-primary text-white' : 'bg-white text-gray-700 hover:bg-gray-50'
            }`}
          >
            All ({statusCounts.all || 0})
          </a>
          {(Object.entries(PACKAGE_STATUS_LABELS || {}) as [
            string,
            (typeof PACKAGE_STATUS_LABELS)[keyof typeof PACKAGE_STATUS_LABELS],
          ][]).map(([status, info]) => (
            <a 
              href={`?status=${status}`}
              class={`inline-flex items-center gap-2 px-4 py-2 rounded-lg font-medium transition ${
                statusFilter === status ? 'bg-primary text-white' : 'bg-white text-gray-700 hover:bg-gray-50'
              }`}
            >
              <span
                class="w-2 h-2 rounded-full"
                style={`background: ${getStatusColor(status)}`}
              />
              <span>{info.label}</span>
              <span class="text-xs text-slate-500">
                ({statusCounts[status] || 0})
              </span>
            </a>
          ))}
        </div>

        <!-- Search -->
        <div class="bg-white rounded-lg shadow-sm p-4 mb-6">
          <form method="GET" class="flex gap-4">
            <div class="flex-1">
              <input 
                type="text" 
                name="search" 
                value={searchQuery}
                placeholder="Search by tracking number, customer, or description..."
                class="input w-full"
              />
            </div>
            {statusFilter && <input type="hidden" name="status" value={statusFilter} />}
            <button type="submit" class="btn-secondary">Search</button>
            {(searchQuery || statusFilter) && (
              <a href="/admin/packages" class="btn-secondary bg-gray-100">Clear</a>
            )}
          </form>
        </div>

        <!-- Packages Table -->
        {packages.length === 0 ? (
          <div class="bg-white rounded-lg shadow-sm p-12 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-blue-50 mb-4">
              <svg
                class="w-8 h-8 text-blue-500"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-gray-700 mb-2">No packages found</h3>
            <p class="text-gray-500">Try adjusting your search or filter criteria</p>
          </div>
        ) : (
          <>
            <div class="bg-white rounded-lg shadow-sm overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full">
                  <thead class="bg-gray-50 border-b border-gray-200">
                    <tr>
                      <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Tracking Number</th>
                      <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Customer</th>
                      <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Store</th>
                      <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Weight</th>
                      <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                      <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                      <th class="text-left px-6 py-3 text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-gray-200">
                    {packages.map((pkg: any) => {
                      const statusInfo = PACKAGE_STATUS_LABELS[pkg.status as keyof typeof PACKAGE_STATUS_LABELS];
                      return (
                        <tr class="hover:bg-gray-50">
                          <td class="px-6 py-4 whitespace-nowrap">
                            <div class="font-mono text-sm font-medium text-primary">
                              {pkg.original_tracking_number || pkg.mgg_tracking_number}
                            </div>
                          </td>
                          <td class="px-6 py-4">
                            <div class="font-medium text-gray-900">{pkg.customer_name || 'Unknown'}</div>
                            <div class="text-xs text-gray-500">{pkg.customer_email}</div>
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-900">{pkg.store_name || '-'}</div>
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap">
                            <div class="text-sm text-gray-900">{pkg.weight_lbs ? `${pkg.weight_lbs} lbs` : '-'}</div>
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap">
                            <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                              pkg.status === 'ready' ? 'bg-green-100 text-green-800' :
                              pkg.status === 'picked_up' ? 'bg-gray-100 text-gray-600' :
                              pkg.status === 'in_transit' ? 'bg-blue-100 text-blue-800' :
                              pkg.status === 'customs' ? 'bg-purple-100 text-purple-800' :
                              pkg.status === 'at_warehouse' ? 'bg-yellow-100 text-yellow-800' :
                              'bg-orange-100 text-orange-800'
                            }`}>
                              {statusInfo?.icon} {statusInfo?.label}
                            </span>
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                            {formatDate(pkg.registered_at)}
                          </td>
                          <td class="px-6 py-4 whitespace-nowrap text-sm">
                            <div class="flex gap-2">
                              <button 
                                hx-get={`/api/admin/packages/${pkg.id}`}
                                hx-target="#modal-content"
                                onclick="document.getElementById('modal').classList.remove('hidden')"
                                class="text-primary hover:text-primary/80"
                              >
                                Update Status
                              </button>
                            </div>
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>
            </div>

            <!-- Pagination -->
            {totalPages > 1 && (
              <div class="flex items-center justify-between mt-4">
                <div class="text-sm text-gray-500">
                  Showing {(page - 1) * perPage + 1} to {Math.min(page * perPage, total)} of {total} packages
                </div>
                <div class="flex gap-2">
                  {page > 1 && (
                    <a 
                      href={`?page=${page - 1}${statusFilter ? `&status=${statusFilter}` : ''}${searchQuery ? `&search=${searchQuery}` : ''}`}
                      class="px-4 py-2 bg-white rounded-lg hover:bg-gray-50"
                    >
                      Previous
                    </a>
                  )}
                  {page < totalPages && (
                    <a 
                      href={`?page=${page + 1}${statusFilter ? `&status=${statusFilter}` : ''}${searchQuery ? `&search=${searchQuery}` : ''}`}
                      class="px-4 py-2 bg-white rounded-lg hover:bg-gray-50"
                    >
                      Next
                    </a>
                  )}
                </div>
              </div>
            )}
          </>
        )}
      </div>
    </main>
  </div>

  <!-- Modal -->
  <div id="modal" class="hidden fixed inset-0 z-50 overflow-y-auto">
    <div class="items-center justify-center min-h-screen px-4">
      <div class="fixed inset-0 bg-black/50" onclick="document.getElementById('modal').classList.add('hidden')"></div>
      <div class="relative bg-white rounded-lg max-w-lg w-full shadow-xl">
        <div id="modal-content">
          <!-- Content loaded via HTMX -->
          <div class="p-8 text-center text-gray-500">Loading...</div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
