---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminSidebar from "../../components/admin/AdminSidebar.astro";
import DashboardHeader from "../../components/admin/DashboardHeader.astro";
import db from "../../lib/db";

const staff = Astro.locals.staff;

if (!staff) {
    return new Response("Unauthorized", { status: 401 });
}

// Get filter parameters from URL
const url = new URL(Astro.request.url);
const statusFilter = url.searchParams.get("status") || "all";
const ratingFilter = url.searchParams.get("rating") || "";
const dateFromFilter = url.searchParams.get("date_from") || "";
const dateToFilter = url.searchParams.get("date_to") || "";
const searchFilter = url.searchParams.get("search") || "";

let successMessage = "";
let errorMessage = "";

if (Astro.request.method === "POST") {
    const formData = await Astro.request.formData();
    const action = formData.get("action")?.toString();
    const commentId = formData.get("comment_id")?.toString();

    if (!commentId) {
        errorMessage = "Missing comment id.";
    } else if (action === "approve") {
        try {
            await db.execute({
                sql: `UPDATE comments SET is_approved = 1 WHERE id = ?`,
                args: [commentId],
            });
            successMessage = "Review approved and published.";
        } catch (e) {
            ;
            errorMessage = "Failed to approve review. Please try again.";
        }
    } else if (action === "delete") {
        try {
            await db.execute({
                sql: `DELETE FROM comments WHERE id = ?`,
                args: [commentId],
            });
            successMessage = "Review deleted.";
        } catch (e) {
            ;
            errorMessage = "Failed to delete review. Please try again.";
        }
    } else {
        errorMessage = "Invalid action.";
    }
}

// Build dynamic SQL with filters
function buildFilteredQuery(baseStatusCondition: string): {
    sql: string;
    args: any[];
} {
    let sql = `
        SELECT 
          c.id,
          c.rating,
          c.comment,
          c.created_at,
          u.name AS customer_name,
          u.customer_code
        FROM comments c
        JOIN users u ON c.user_id = u.id
        WHERE ${baseStatusCondition}
    `;

    const args: any[] = [];

    // Rating filter
    if (ratingFilter) {
        sql += ` AND c.rating = ?`;
        args.push(parseInt(ratingFilter));
    }

    // Date range filter
    if (dateFromFilter) {
        sql += ` AND c.created_at >= ?`;
        args.push(Math.floor(new Date(dateFromFilter).getTime() / 1000));
    }

    if (dateToFilter) {
        // Add 1 day to include the end date fully
        const endDate = new Date(dateToFilter);
        endDate.setDate(endDate.getDate() + 1);
        sql += ` AND c.created_at < ?`;
        args.push(Math.floor(endDate.getTime() / 1000));
    }

    // Search filter (customer name or comment text)
    if (searchFilter) {
        sql += ` AND (u.name LIKE ? OR c.comment LIKE ?)`;
        const searchPattern = `%${searchFilter}%`;
        args.push(searchPattern, searchPattern);
    }

    sql += ` ORDER BY c.created_at DESC`;

    return { sql, args };
}

// Get reviews based on status filter
let pendingReviews: any[] = [];
let approvedReviews: any[] = [];
let allReviews: any[] = [];

if (statusFilter === "pending") {
    const { sql, args } = buildFilteredQuery("c.is_approved = 0");
    const result = await db.execute({ sql, args });
    pendingReviews = result.rows as any[];
} else if (statusFilter === "approved") {
    const { sql, args } = buildFilteredQuery("c.is_approved = 1");
    const result = await db.execute({ sql, args });
    approvedReviews = result.rows as any[];
} else {
    // Show both pending and approved
    const pendingQuery = buildFilteredQuery("c.is_approved = 0");
    const pendingResult = await db.execute({
        sql: pendingQuery.sql,
        args: pendingQuery.args,
    });
    pendingReviews = pendingResult.rows as any[];

    const approvedQuery = buildFilteredQuery("c.is_approved = 1");
    const approvedResult = await db.execute({
        sql: approvedQuery.sql,
        args: approvedQuery.args,
    });
    approvedReviews = approvedResult.rows as any[];
}

// Get counts for display
const pendingCount = pendingReviews.length;
const approvedCount = approvedReviews.length;
---

<BaseLayout title="Customer Reviews">
    <div class="min-h-screen">
        <AdminSidebar />

        <main
            class="md:ml-64 bg-[#f1f5f9] min-h-screen transition-all duration-300"
        >
            <DashboardHeader
                title="Customer Reviews"
                subtitle="Review and publish customer feedback for the website"
            />

            <div class="p-8 space-y-8">
                {
                    errorMessage && (
                        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg">
                            {errorMessage}
                        </div>
                    )
                }
                {
                    successMessage && (
                        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg">
                            {successMessage}
                        </div>
                    )
                }

                <!-- Filters Section -->
                <section class="bg-white rounded-lg shadow-sm p-6">
                    <div class="flex items-center justify-between mb-4">
                        <h2 class="text-lg font-semibold text-gray-900">
                            Filters
                        </h2>
                        <div class="text-sm text-gray-500">
                            {pendingCount} pending · {approvedCount} approved
                        </div>
                    </div>

                    <form method="GET" class="space-y-4">
                        <div
                            class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4"
                        >
                            <!-- Status Filter -->
                            <div>
                                <label
                                    for="status"
                                    class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"
                                >
                                    Status
                                </label>
                                <select
                                    id="status"
                                    name="status"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                >
                                    <option
                                        value="all"
                                        selected={statusFilter === "all"}
                                        >All Reviews</option
                                    >
                                    <option
                                        value="pending"
                                        selected={statusFilter === "pending"}
                                        >Pending Only</option
                                    >
                                    <option
                                        value="approved"
                                        selected={statusFilter === "approved"}
                                        >Approved Only</option
                                    >
                                </select>
                            </div>

                            <!-- Rating Filter -->
                            <div>
                                <label
                                    for="rating"
                                    class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"
                                >
                                    Rating
                                </label>
                                <select
                                    id="rating"
                                    name="rating"
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                >
                                    <option value="">All Ratings</option>
                                    <option
                                        value="5"
                                        selected={ratingFilter === "5"}
                                        >★★★★★ 5 Stars</option
                                    >
                                    <option
                                        value="4"
                                        selected={ratingFilter === "4"}
                                        >★★★★☆ 4 Stars</option
                                    >
                                    <option
                                        value="3"
                                        selected={ratingFilter === "3"}
                                        >★★★☆☆ 3 Stars</option
                                    >
                                    <option
                                        value="2"
                                        selected={ratingFilter === "2"}
                                        >★★☆☆☆ 2 Stars</option
                                    >
                                    <option
                                        value="1"
                                        selected={ratingFilter === "1"}
                                        >★☆☆☆☆ 1 Star</option
                                    >
                                </select>
                            </div>

                            <!-- Date From Filter -->
                            <div>
                                <label
                                    for="date_from"
                                    class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"
                                >
                                    Date From
                                </label>
                                <input
                                    type="date"
                                    id="date_from"
                                    name="date_from"
                                    value={dateFromFilter}
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                />
                            </div>

                            <!-- Date To Filter -->
                            <div>
                                <label
                                    for="date_to"
                                    class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"
                                >
                                    Date To
                                </label>
                                <input
                                    type="date"
                                    id="date_to"
                                    name="date_to"
                                    value={dateToFilter}
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                />
                            </div>

                            <!-- Search Filter -->
                            <div>
                                <label
                                    for="search"
                                    class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1"
                                >
                                    Search
                                </label>
                                <input
                                    type="text"
                                    id="search"
                                    name="search"
                                    value={searchFilter}
                                    placeholder="Customer name or comment..."
                                    class="w-full px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                                />
                            </div>
                        </div>

                        <!-- Filter Actions -->
                        <div class="flex items-center justify-end space-x-3">
                            <a
                                href="/admin/reviews"
                                class="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors"
                            >
                                Clear Filters
                            </a>
                            <button
                                type="submit"
                                class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-md hover:bg-blue-700 transition-colors"
                            >
                                Apply Filters
                            </button>
                        </div>
                    </form>
                </section>

                {
                    statusFilter !== "approved" && (
                        <section class="bg-white rounded-lg shadow-sm p-6">
                            <div class="flex items-center justify-between mb-4">
                                <h2 class="text-lg font-semibold text-gray-900">
                                    Pending Reviews
                                    <span class="ml-2 text-sm font-normal text-gray-500">
                                        ({pendingCount})
                                    </span>
                                </h2>
                                <p class="text-sm text-gray-500">
                                    Approve reviews to feature them on the
                                    homepage and reviews page.
                                </p>
                            </div>

                            {pendingReviews.length === 0 ? (
                                <div class="text-center py-8">
                                    <svg
                                        class="mx-auto h-12 w-12 text-gray-400"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                        />
                                    </svg>
                                    <p class="mt-2 text-sm text-gray-500">
                                        {statusFilter === "pending" &&
                                        (ratingFilter ||
                                            dateFromFilter ||
                                            dateToFilter ||
                                            searchFilter)
                                            ? "No reviews match your current filters."
                                            : "There are no pending reviews at the moment."}
                                    </p>
                                </div>
                            ) : (
                                <div class="overflow-x-auto -mx-4 sm:mx-0">
                                    <table class="min-w-full text-sm">
                                        <thead class="bg-gray-50">
                                            <tr>
                                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
                                                    Customer
                                                </th>
                                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
                                                    Rating
                                                </th>
                                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
                                                    Comment
                                                </th>
                                                <th class="px-4 py-2 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">
                                                    Submitted
                                                </th>
                                                <th class="px-4 py-2 text-right text-xs font-semibold text-gray-500 uppercase tracking-wide">
                                                    Actions
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody class="divide-y divide-gray-200">
                                            {pendingReviews.map(
                                                (review: any) => (
                                                    <tr>
                                                        <td class="px-4 py-3 align-top">
                                                            <div class="font-medium text-gray-900">
                                                                {
                                                                    (
                                                                        review.customer_name ||
                                                                        "MGG Customer"
                                                                    ).split(
                                                                        " ",
                                                                    )[0]
                                                                }
                                                            </div>
                                                        </td>
                                                        <td class="px-4 py-3 align-top">
                                                            <div class="flex items-center text-yellow-500 text-xs">
                                                                {Array.from({
                                                                    length: 5,
                                                                }).map(
                                                                    (_, i) => (
                                                                        <span>
                                                                            {i <
                                                                            (review.rating ||
                                                                                5)
                                                                                ? "★"
                                                                                : "☆"}
                                                                        </span>
                                                                    ),
                                                                )}
                                                            </div>
                                                        </td>
                                                        <td class="px-4 py-3 align-top max-w-md">
                                                            <p class="text-sm text-gray-800 whitespace-pre-line">
                                                                {review.comment}
                                                            </p>
                                                        </td>
                                                        <td class="px-4 py-3 align-top text-xs text-gray-500">
                                                            {new Date(
                                                                review.created_at *
                                                                    1000,
                                                            ).toLocaleString(
                                                                "en-GY",
                                                                {
                                                                    day: "2-digit",
                                                                    month: "short",
                                                                    year: "numeric",
                                                                    hour: "2-digit",
                                                                    minute: "2-digit",
                                                                },
                                                            )}
                                                        </td>
                                                        <td class="px-4 py-3 align-top text-right space-y-2">
                                                            <form
                                                                method="POST"
                                                                class="inline"
                                                            >
                                                                <input
                                                                    type="hidden"
                                                                    name="action"
                                                                    value="approve"
                                                                />
                                                                <input
                                                                    type="hidden"
                                                                    name="comment_id"
                                                                    value={
                                                                        review.id
                                                                    }
                                                                />
                                                                <button
                                                                    type="submit"
                                                                    class="inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-green-600 text-white hover:bg-green-700"
                                                                >
                                                                    Approve
                                                                </button>
                                                            </form>
                                                            <form
                                                                method="POST"
                                                                class="inline ml-2"
                                                                onsubmit="return confirm('Delete this review? This cannot be undone.')"
                                                            >
                                                                <input
                                                                    type="hidden"
                                                                    name="action"
                                                                    value="delete"
                                                                />
                                                                <input
                                                                    type="hidden"
                                                                    name="comment_id"
                                                                    value={
                                                                        review.id
                                                                    }
                                                                />
                                                                <button
                                                                    type="submit"
                                                                    class="inline-flex items-center px-3 py-1.5 rounded-md text-xs font-semibold bg-red-600 text-white hover:bg-red-700"
                                                                >
                                                                    Delete
                                                                </button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                ),
                                            )}
                                        </tbody>
                                    </table>
                                </div>
                            )}
                        </section>
                    )
                }

                {
                    statusFilter !== "pending" && (
                        <section class="bg-white rounded-lg shadow-sm p-6">
                            <div class="flex items-center justify-between mb-4">
                                <h2 class="text-lg font-semibold text-gray-900">
                                    {statusFilter === "approved"
                                        ? "Approved Reviews"
                                        : "Recently Approved Reviews"}
                                    <span class="ml-2 text-sm font-normal text-gray-500">
                                        ({approvedCount})
                                    </span>
                                </h2>
                                <p class="text-sm text-gray-500">
                                    These reviews are currently visible on the
                                    public site.
                                </p>
                            </div>

                            {approvedReviews.length === 0 ? (
                                <div class="text-center py-8">
                                    <svg
                                        class="mx-auto h-12 w-12 text-gray-400"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                        />
                                    </svg>
                                    <p class="mt-2 text-sm text-gray-500">
                                        {statusFilter === "approved" &&
                                        (ratingFilter ||
                                            dateFromFilter ||
                                            dateToFilter ||
                                            searchFilter)
                                            ? "No reviews match your current filters."
                                            : "No approved reviews yet. Once you approve reviews, they will show up here."}
                                    </p>
                                </div>
                            ) : (
                                <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                                    {approvedReviews.map((review: any) => (
                                        <article class="border border-gray-200 rounded-lg p-4 bg-gray-50">
                                            <div class="flex items-center justify-between mb-2">
                                                <div>
                                                    <h3 class="text-sm font-semibold text-gray-900">
                                                        {
                                                            (
                                                                review.customer_name ||
                                                                "MGG Customer"
                                                            ).split(" ")[0]
                                                        }
                                                    </h3>
                                                </div>
                                                <div class="text-yellow-500 text-xs">
                                                    {Array.from({
                                                        length: 5,
                                                    }).map((_, i) => (
                                                        <span>
                                                            {i <
                                                            (review.rating || 5)
                                                                ? "★"
                                                                : "☆"}
                                                        </span>
                                                    ))}
                                                </div>
                                            </div>
                                            <p class="text-sm text-gray-800 whitespace-pre-line mb-2">
                                                {review.comment}
                                            </p>
                                            <p class="text-xs text-gray-500">
                                                {new Date(
                                                    review.created_at * 1000,
                                                ).toLocaleDateString("en-GY", {
                                                    day: "2-digit",
                                                    month: "short",
                                                    year: "numeric",
                                                })}
                                            </p>
                                        </article>
                                    ))}
                                </div>
                            )}
                        </section>
                    )
                }
            </div>
        </main>
    </div>
</BaseLayout>
