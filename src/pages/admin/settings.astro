---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminSidebar from "../../components/admin/AdminSidebar.astro";
import DashboardHeader from "../../components/admin/DashboardHeader.astro";
import db from "../../lib/db";

const staff = Astro.locals.staff!;

// Get current settings
const settingsResult = await db.execute({
  sql: `SELECT key, value FROM settings`,
  args: [],
});
const settings: Record<string, string> = {};
settingsResult.rows.forEach((row: any) => {
  settings[row.key] = row.value;
});

// Handle form submission
let success = false;
let error = "";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();

    const settingKeys = [
      "shipping_rate_per_lb",
      "exchange_rate",
      "free_storage_days",
      "storage_fee_per_day",
      "warehouse_address",
      "contact_phone",
      "contact_email",
      "business_hours",
    ];

    for (const key of settingKeys) {
      const value = formData.get(key)?.toString() || "";

      await db.execute({
        sql: `INSERT INTO settings (key, value) VALUES (?, ?)
              ON CONFLICT(key) DO UPDATE SET value = excluded.value`,
        args: [key, value],
      });
    }

    success = true;

    // Refresh settings
    const refreshResult = await db.execute({
      sql: `SELECT key, value FROM settings`,
      args: [],
    });
    refreshResult.rows.forEach((row: any) => {
      settings[row.key] = row.value;
    });
  } catch (e) {
    error = "Failed to save settings. Please try again.";
    ;
  }
}
---

<BaseLayout title="Settings">
  <div class="min-h-screen">
    <AdminSidebar />

    <!-- Main Content -->
    <main
      class="md:ml-64 bg-[#f1f5f9] min-h-screen transition-all duration-300"
    >
      <DashboardHeader
        title="Settings"
        subtitle="Configure your shipping rates and business settings"
      />

      <!-- Content -->
      <div class="p-4 md:p-8">
        {
          success && (
            <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6">
              ✓ Settings saved successfully
            </div>
          )
        }

        {
          error && (
            <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6">
              {error}
            </div>
          )
        }

        <form method="POST" class="space-y-6">
          <!-- Shipping Rates -->
          <div class="bg-white rounded-lg shadow-sm p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">
              💰 Shipping Rates
            </h2>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label
                  for="shipping_rate_per_lb"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  Shipping Rate (per lb)
                </label>
                <div class="relative">
                  <input
                    type="number"
                    id="shipping_rate_per_lb"
                    name="shipping_rate_per_lb"
                    value={settings["shipping_rate_per_lb"] || "500"}
                    class="input pr-16"
                    placeholder="500"
                  />
                  <span
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500"
                    >GYD $</span
                  >
                </div>
                <p class="text-xs text-gray-500 mt-1">
                  Default: GYD $500 per pound
                </p>
              </div>

              <div>
                <label
                  for="exchange_rate"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  USD to GYD Exchange Rate
                </label>
                <div class="relative">
                  <input
                    type="number"
                    id="exchange_rate"
                    name="exchange_rate"
                    value={settings["exchange_rate"] || "222"}
                    class="input pr-16"
                    placeholder="222"
                  />
                  <span
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500"
                    >GYD</span
                  >
                </div>
                <p class="text-xs text-gray-500 mt-1">
                  Current rate approximately 222 GYD per USD
                </p>
              </div>
            </div>
          </div>

          <!-- Storage Fees -->
          <div class="bg-white rounded-lg shadow-sm p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">
              📦 Storage Fees
            </h2>

            <div class="grid md:grid-cols-2 gap-6">
              <div>
                <label
                  for="free_storage_days"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  Free Storage Period
                </label>
                <div class="relative">
                  <input
                    type="number"
                    id="free_storage_days"
                    name="free_storage_days"
                    value={settings["free_storage_days"] || "7"}
                    class="input pr-12"
                    placeholder="7"
                  />
                  <span
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500"
                    >days</span
                  >
                </div>
                <p class="text-xs text-gray-500 mt-1">
                  Number of free days before storage fees apply
                </p>
              </div>

              <div>
                <label
                  for="storage_fee_per_day"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  Storage Fee (per day)
                </label>
                <div class="relative">
                  <input
                    type="number"
                    id="storage_fee_per_day"
                    name="storage_fee_per_day"
                    value={settings["storage_fee_per_day"] || "500"}
                    class="input pr-16"
                    placeholder="500"
                  />
                  <span
                    class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-500"
                    >GYD $</span
                  >
                </div>
                <p class="text-xs text-gray-500 mt-1">
                  Charged per package per day after free period
                </p>
              </div>
            </div>
          </div>

          <!-- Business Information -->
          <div class="bg-white rounded-lg shadow-sm p-6">
            <h2 class="text-lg font-semibold text-gray-900 mb-4">
              🏢 Business Information
            </h2>

            <div class="space-y-6">
              <div>
                <label
                  for="warehouse_address"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  US Warehouse Address
                </label>
                <textarea
                  id="warehouse_address"
                  name="warehouse_address"
                  rows="3"
                  class="input"
                  placeholder="Enter the full US warehouse address for customers to ship their packages"
                  >{settings["warehouse_address"] || ""}</textarea
                >
                <p class="text-xs text-gray-500 mt-1">
                  This is the address customers use when shopping online
                </p>
              </div>

              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <label
                    for="contact_phone"
                    class="block text-sm font-medium text-gray-700 mb-1"
                  >
                    Contact Phone
                  </label>
                  <input
                    type="tel"
                    id="contact_phone"
                    name="contact_phone"
                    value={settings["contact_phone"] || ""}
                    class="input"
                    placeholder="+592 123-4567"
                  />
                </div>

                <div>
                  <label
                    for="contact_email"
                    class="block text-sm font-medium text-gray-700 mb-1"
                  >
                    Contact Email
                  </label>
                  <input
                    type="email"
                    id="contact_email"
                    name="contact_email"
                    value={settings["contact_email"] || ""}
                    class="input"
                    placeholder="info@mendoncaglobal.com"
                  />
                </div>
              </div>

              <div>
                <label
                  for="business_hours"
                  class="block text-sm font-medium text-gray-700 mb-1"
                >
                  Business Hours
                </label>
                <input
                  type="text"
                  id="business_hours"
                  name="business_hours"
                  value={settings["business_hours"] || ""}
                  class="input"
                  placeholder="Mon-Fri: 9AM-5PM, Sat: 9AM-1PM"
                />
              </div>
            </div>
          </div>

          <!-- Save Button -->
          <div class="flex justify-end">
            <button type="submit" class="btn-primary px-8">
              Save Settings
            </button>
          </div>
        </form>

        <!-- Danger Zone -->
        <div
          class="bg-white rounded-lg shadow-sm p-6 mt-8 border-2 border-red-200"
        >
          <h2 class="text-lg font-semibold text-red-600 mb-4">
            ⚠️ Danger Zone
          </h2>
          <p class="text-gray-600 mb-4">
            These actions are irreversible. Please be careful.
          </p>
          <div class="flex gap-4">
            <button
              class="px-4 py-2 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition"
              disabled
              title="Coming soon"
            >
              Export All Data
            </button>
            <button
              class="px-4 py-2 bg-red-100 text-red-700 rounded-lg hover:bg-red-200 transition"
              disabled
              title="Coming soon"
            >
              Reset Settings
            </button>
          </div>
        </div>
      </div>
    </main>
  </div>
</BaseLayout>
