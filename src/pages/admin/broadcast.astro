---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AdminSidebar from "../../components/admin/AdminSidebar.astro";
import DashboardHeader from "../../components/admin/DashboardHeader.astro";

const staff = Astro.locals.staff!;
---

<BaseLayout title="Customer Broadcast Email - Admin">
    <div class="min-h-screen">
        <AdminSidebar currentPath="/admin/broadcast" />

        <main
            class="md:ml-64 bg-[#f1f5f9] min-h-screen transition-all duration-300"
        >
            <DashboardHeader userName={staff.name} title="Broadcast" />

            <!-- Scrollable Content -->
            <div class="p-4 lg:p-8">
                <div class="max-w-4xl mx-auto space-y-6">
                    <div class="flex justify-between items-center">
                        <div>
                            <h1
                                class="text-2xl font-bold text-gray-900 tracking-tight"
                            >
                                Customer Broadcast
                            </h1>
                            <p class="text-sm text-gray-500 mt-1">
                                Send an email announcement to all registered
                                customers.
                            </p>
                        </div>
                    </div>

                    <div
                        class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden"
                    >
                        <div class="p-6">
                            <form id="broadcast-form" class="space-y-6">
                                <!-- Subject -->
                                <div>
                                    <label
                                        for="subject"
                                        class="block text-sm font-medium text-gray-700 mb-1"
                                    >
                                        Email Subject <span class="text-red-500"
                                            >*</span
                                        >
                                    </label>
                                    <input
                                        type="text"
                                        id="subject"
                                        name="subject"
                                        required
                                        placeholder="e.g. Holiday Shipping Schedule Updates"
                                        class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-primary focus:border-primary sm:text-sm"
                                    />
                                </div>

                                <!-- Rich Text Editor -->
                                <div>
                                    <label
                                        class="block text-sm font-medium text-gray-700 mb-1"
                                    >
                                        Email Message <span class="text-red-500"
                                            >*</span
                                        >
                                    </label>
                                    <div
                                        class="border border-gray-300 rounded-lg"
                                    >
                                        <div
                                            id="editor-container"
                                            class="min-h-[250px] bg-white rounded-b-lg"
                                        >
                                        </div>
                                    </div>
                                    <input
                                        type="hidden"
                                        name="message"
                                        id="message-content"
                                    />
                                </div>

                                <!-- Error / Success Messages -->
                                <div
                                    id="status-message"
                                    class="hidden rounded-md p-4 text-sm"
                                >
                                </div>

                                <!-- Submit Button -->
                                <div
                                    class="flex items-center justify-end pt-4 border-t border-gray-100"
                                >
                                    <button
                                        type="button"
                                        id="send-broadcast"
                                        class="btn-primary flex items-center justify-center gap-2"
                                    >
                                        <svg
                                            class="w-4 h-4"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"
                                            ></path>
                                        </svg>
                                        <span>Send to All Customers</span>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Include Quill.js for Rich Text Formatting -->
    <link
        href="https://cdn.quilljs.com/1.3.6/quill.snow.css"
        rel="stylesheet"
    />
    <script is:inline src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

    <script is:inline>
        function initQuill() {
            // @ts-ignore
            if (
                window.quillInitialized ||
                !document.getElementById("editor-container")
            )
                return;
            window.quillInitialized = true;

            const quill = new Quill("#editor-container", {
                theme: "snow",
                placeholder: "Write your email broadcast here...",
                modules: {
                    toolbar: [
                        [{ header: [1, 2, 3, false] }],
                        ["bold", "italic", "underline", "strike"],
                        [{ list: "ordered" }, { list: "bullet" }],
                        ["link", "clean"],
                    ],
                },
            });

            const btn = document.getElementById("send-broadcast");
            const statusMessage = document.getElementById("status-message");
            const subjectInput = document.getElementById("subject");

            btn.addEventListener("click", async () => {
                // Collect data
                const subject = subjectInput.value.trim();
                const htmlContent = quill.root.innerHTML;
                const textContent = quill.getText().trim();

                if (!subject) {
                    showStatus("Please enter a subject.", "error");
                    return;
                }
                if (!textContent) {
                    showStatus("Please enter an email message.", "error");
                    return;
                }

                const isConfirmed = await new Promise((resolve) => {
                    if (window.showModal) {
                        window.showModal(
                            "Are you sure you want to send this email to EVERY registered customer? This cannot be undone.",
                            () => resolve(true),
                            () => resolve(false),
                        );
                    } else {
                        resolve(
                            confirm(
                                "Are you sure you want to send this email to EVERY registered customer? This cannot be undone.",
                            ),
                        );
                    }
                });

                if (!isConfirmed) {
                    return;
                }

                // Send
                btn.disabled = true;
                btn.innerHTML = `<span class="opacity-0">Send to All Customers</span><div class="absolute inset-0 flex items-center justify-center"><svg class="animate-spin h-5 w-5 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg></div>`;
                btn.classList.add("relative");
                showStatus("Sending broadcast emails... please wait.", "info");

                try {
                    const res = await fetch("/api/admin/broadcast", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({ subject, html: htmlContent }),
                    });

                    const data = await res.json();

                    if (res.ok) {
                        showStatus(
                            `Successfully queued broadcast to ${data.count} customers.`,
                            "success",
                        );
                        subjectInput.value = "";
                        quill.root.innerHTML = "";
                    } else {
                        showStatus(
                            data.error || "Failed to send broadcast.",
                            "error",
                        );
                    }
                } catch (e) {
                    showStatus(
                        "An unexpected network error occurred.",
                        "error",
                    );
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = `<svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg><span>Send to All Customers</span>`;
                }
            });

            function showStatus(text, type) {
                statusMessage.classList.remove(
                    "hidden",
                    "bg-red-50",
                    "text-red-800",
                    "bg-green-50",
                    "text-green-800",
                    "bg-blue-50",
                    "text-blue-800",
                );
                if (type === "error") {
                    statusMessage.classList.add("bg-red-50", "text-red-800");
                } else if (type === "success") {
                    statusMessage.classList.add(
                        "bg-green-50",
                        "text-green-800",
                    );
                } else {
                    statusMessage.classList.add("bg-blue-50", "text-blue-800");
                }
                statusMessage.textContent = text;
            }
        }

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initQuill);
        } else {
            initQuill();
        }
    </script>

    <style is:global>
        /* Quill Editor Adjustments */
        .ql-toolbar.ql-snow {
            border: none !important;
            border-bottom: 1px solid #e5e7eb !important;
            background-color: #f9fafb !important;
            border-radius: 0.5rem 0.5rem 0 0 !important;
            padding: 12px 16px !important;
        }
        .ql-container.ql-snow {
            border: none !important;
            font-family: inherit !important;
            font-size: 1rem !important;
        }
        .ql-editor {
            min-height: 250px;
        }
    </style>
</BaseLayout>
