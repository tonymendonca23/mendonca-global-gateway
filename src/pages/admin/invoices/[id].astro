---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AdminSidebar from "../../../components/admin/AdminSidebar.astro";
import DashboardHeader from "../../../components/admin/DashboardHeader.astro";
import db from "../../../lib/db";
import { formatDate, formatGYD, formatUSD } from "../../../lib/utils";
import { sendInvoiceEmail } from "../../../lib/email";
import { createInvoiceFileLink } from "../../../lib/auth";

const staff = Astro.locals.staff!;
const id = Astro.params.id!;

let successMessage = "";
let errorMessage = "";

// Load invoice and customer
const invoiceResult = await db.execute({
    sql: `
    SELECT 
      i.*, 
      u.email as customer_email,
      u.name as customer_name,
      u.phone as customer_phone
    FROM invoices i
    LEFT JOIN users u ON i.customer_id = u.id
    WHERE i.id = ?
  `,
    args: [id],
});

const invoice = invoiceResult.rows[0] as any;

if (!invoice) {
    throw new Error("Invoice not found");
}

// Load packages linked to this invoice
const packagesResult = await db.execute({
    sql: `
    SELECT p.*
    FROM invoice_line_items il
    JOIN packages p ON il.package_id = p.id
    WHERE il.invoice_id = ?
    ORDER BY p.registered_at DESC
  `,
    args: [id],
});

const packages = packagesResult.rows as any[];

// Aggregate weight for summary rows
const totalWeightLbs = packages.reduce(
    (sum, pkg: any) => sum + (pkg.weight_lbs || 0),
    0,
);

const hasPdf =
    (invoice.invoice_file_size && Number(invoice.invoice_file_size) > 0) ||
    !!invoice.invoice_file_url;
const pdfHref = invoice.invoice_file_size
    ? `/api/invoices/${id}/file`
    : invoice.invoice_file_url;

// Read query params for email success/error
const url = new URL(Astro.request.url);
if (url.searchParams.get("sent") === "1") {
    successMessage = "Invoice email sent to customer.";
}
if (url.searchParams.get("error") === "no-pdf") {
    errorMessage = "Upload the invoice PDF before emailing it to the customer.";
}

// Handle optional PDF upload/update (and email customer once uploaded)
if (Astro.request.method === "POST") {
    try {
        const formData = await Astro.request.formData();
        const uploadedFile = formData.get("invoice_file") as File | null;

        if (!uploadedFile || uploadedFile.size === 0) {
            errorMessage = "Please select a PDF file to upload";
        } else if (uploadedFile.type !== "application/pdf") {
            errorMessage = "Invoice file must be a PDF";
        } else {
            const buffer = Buffer.from(await uploadedFile.arrayBuffer());
            const safeName = uploadedFile.name.replace(/[^a-zA-Z0-9_.-]/g, "_");
            const filename = `${invoice.invoice_number}-${safeName || "invoice.pdf"}`;
            const mimeType = uploadedFile.type || "application/pdf";
            const size = buffer.length;
            const uploadedAt = Math.floor(Date.now() / 1000);

            await db.execute({
                sql: `UPDATE invoices 
                      SET invoice_file_data = ?,
                          invoice_file_name = ?,
                          invoice_file_mime = ?,
                          invoice_file_size = ?,
                          invoice_file_uploaded_at = ?
                      WHERE id = ?`,
                args: [buffer, filename, mimeType, size, uploadedAt, id],
            });

            invoice.invoice_file_name = filename;
            invoice.invoice_file_mime = mimeType;
            invoice.invoice_file_size = size;
            invoice.invoice_file_uploaded_at = uploadedAt;

            // Try to email the invoice to the customer automatically
            try {
                const siteUrl =
                    import.meta.env.PUBLIC_SITE_URL || "http://localhost:4321";
                const fullUrl = createInvoiceFileLink(id, siteUrl);

                const result = await sendInvoiceEmail({
                    email: invoice.customer_email,
                    name: invoice.customer_name,
                    invoiceNumber: invoice.invoice_number,
                    totalGyd: invoice.total_gyd || 0,
                    invoiceUrl: fullUrl,
                });

                if (result.success) {
                    successMessage =
                        "Invoice PDF uploaded and emailed to the customer.";
                    errorMessage = "";
                } else {
                    successMessage =
                        "Invoice PDF uploaded, but sending the email failed. Please check your email settings.";
                }
            } catch (err) {
                console.error(
                    "Failed to send invoice email after upload:",
                    err,
                );
                successMessage =
                    "Invoice PDF uploaded, but sending the email failed. Please check your email settings.";
            }
        }
    } catch (e) {
        errorMessage = "Failed to upload invoice PDF. Please try again.";
    }
}
---

<BaseLayout title={`Invoice ${invoice.invoice_number}`}>
    <div class="min-h-screen">
        <AdminSidebar />

        <main
            class="md:ml-64 bg-[#f1f5f9] min-h-screen transition-all duration-300"
        >
            <DashboardHeader
                title={`Invoice ${invoice.invoice_number}`}
                subtitle="Review charges and linked packages"
            >
                <a href="/admin/invoices" class="btn-secondary"
                    >← Back to Invoices</a
                >
            </DashboardHeader>

            <div class="p-8 space-y-6">
                {
                    errorMessage && (
                        <div class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg">
                            {errorMessage}
                        </div>
                    )
                }
                {
                    successMessage && (
                        <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg">
                            {successMessage}
                        </div>
                    )
                }

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <div class="lg:col-span-2 space-y-4">
                        <div class="bg-white rounded-lg shadow-sm p-6">
                            <div class="flex justify-between items-start mb-4">
                                <div>
                                    <div class="text-sm text-gray-500">
                                        Invoice Number
                                    </div>
                                    <div
                                        class="font-mono font-semibold text-lg"
                                    >
                                        {invoice.invoice_number}
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="text-sm text-gray-500">
                                        Status
                                    </div>
                                    <span
                                        class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
                                            invoice.status === "paid"
                                                ? "bg-green-100 text-green-800"
                                                : "bg-red-100 text-red-800"
                                        }`}
                                    >
                                        {
                                            invoice.status === "paid"
                                                ? "Paid"
                                                : "Unpaid"
                                        }
                                    </span>
                                </div>
                            </div>

                            <div
                                class="grid grid-cols-1 sm:grid-cols-3 gap-4 text-sm"
                            >
                                <div>
                                    <div class="text-gray-500">Customer</div>
                                    <div class="font-medium text-gray-900">
                                        {invoice.customer_name || "Unknown"}
                                    </div>
                                    <div
                                        class="text-gray-500 text-xs break-all"
                                    >
                                        {invoice.customer_email}
                                    </div>
                                    {
                                        invoice.customer_phone && (
                                            <div class="text-gray-500 text-xs mt-1">
                                                {invoice.customer_phone}
                                            </div>
                                        )
                                    }
                                </div>
                                <div>
                                    <div class="text-gray-500">Issued At</div>
                                    <div class="font-medium text-gray-900">
                                        {formatDate(invoice.issued_at)}
                                    </div>
                                    {
                                        invoice.paid_at && (
                                            <div class="mt-2">
                                                <div class="text-gray-500">
                                                    Paid At
                                                </div>
                                                <div class="font-medium text-gray-900">
                                                    {formatDate(
                                                        invoice.paid_at,
                                                    )}
                                                </div>
                                            </div>
                                        )
                                    }
                                </div>
                                <div>
                                    <div class="text-gray-500">Total Due</div>
                                    <div
                                        class="text-xl font-semibold text-primary"
                                    >
                                        {formatGYD(invoice.total_gyd)}
                                    </div>
                                    <div class="text-xs text-gray-500">
                                        {formatUSD(invoice.total_usd)}
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="bg-white rounded-lg shadow-sm p-6">
                            <h2
                                class="text-lg font-semibold text-gray-900 mb-4"
                            >
                                Packages on this Invoice
                            </h2>
                            {
                                packages.length === 0 ? (
                                    <p class="text-sm text-gray-500">
                                        No packages are linked to this invoice.
                                    </p>
                                ) : (
                                    <>
                                        <div class="overflow-x-auto">
                                            <table class="min-w-full text-sm">
                                                <thead class="bg-gray-50">
                                                    <tr>
                                                        <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                            Tracking Numbers
                                                        </th>
                                                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                            Weight (lb)
                                                        </th>
                                                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                            Rate per lb
                                                        </th>
                                                        <th class="px-4 py-2 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
                                                            Total
                                                        </th>
                                                    </tr>
                                                </thead>
                                                <tbody class="divide-y divide-gray-200">
                                                    {packages.map(
                                                        (pkg: any) => {
                                                            const weight =
                                                                pkg.weight_lbs ||
                                                                0;
                                                            const rate =
                                                                invoice.cost_per_lb ||
                                                                0;
                                                            const lineTotal =
                                                                Math.round(
                                                                    weight *
                                                                        rate,
                                                                );
                                                            return (
                                                                <tr>
                                                                    <td class="px-4 py-2 text-gray-900">
                                                                        <div class="font-mono">
                                                                            {pkg.original_tracking_number ||
                                                                                pkg.mgg_tracking_number}
                                                                        </div>
                                                                    </td>
                                                                    <td class="px-4 py-2 text-right text-gray-900">
                                                                        {weight}
                                                                    </td>
                                                                    <td class="px-4 py-2 text-right text-gray-900">
                                                                        {rate
                                                                            ? formatGYD(
                                                                                  rate,
                                                                              )
                                                                            : "-"}
                                                                    </td>
                                                                    <td class="px-4 py-2 text-right text-gray-900">
                                                                        {lineTotal
                                                                            ? formatGYD(
                                                                                  lineTotal,
                                                                              )
                                                                            : "-"}
                                                                    </td>
                                                                </tr>
                                                            );
                                                        },
                                                    )}
                                                    <tr class="bg-gray-50 font-medium">
                                                        <td class="px-4 py-2 text-right uppercase text-xs text-gray-600">
                                                            Total Weight
                                                        </td>
                                                        <td class="px-4 py-2 text-right text-gray-900">
                                                            {totalWeightLbs.toFixed(
                                                                1,
                                                            )}
                                                        </td>
                                                        <td class="px-4 py-2" />
                                                        <td class="px-4 py-2" />
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <p class="mt-3 text-xs text-gray-500">
                                            Notes: A storage fee of GYD $500 per
                                            day may be charged after the last
                                            free day, depending on your
                                            agreement.
                                        </p>
                                    </>
                                )
                            }
                        </div>
                    </div>

                    <div class="space-y-4">
                        <div class="bg-white rounded-lg shadow-sm p-6">
                            <h2
                                class="text-lg font-semibold text-gray-900 mb-4"
                            >
                                Charges Breakdown (GYD)
                            </h2>
                            <dl class="space-y-2 text-sm">
                                <div class="flex justify-between">
                                    <dt class="text-gray-600">
                                        Total Shipping Fee
                                    </dt>
                                    <dd class="font-medium">
                                        {
                                            formatGYD(
                                                invoice.subtotal_shipping || 0,
                                            )
                                        }
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-gray-600">Import Fee</dt>
                                    <dd class="font-medium">
                                        {
                                            formatGYD(
                                                invoice.subtotal_customs || 0,
                                            )
                                        }
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-gray-600">Handling Fee</dt>
                                    <dd class="font-medium">
                                        {
                                            formatGYD(
                                                invoice.import_handling_duty ||
                                                    0,
                                            )
                                        }
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-gray-600">Storage Fee</dt>
                                    <dd class="font-medium">
                                        {
                                            formatGYD(
                                                invoice.subtotal_storage || 0,
                                            )
                                        }
                                    </dd>
                                </div>
                                <div class="flex justify-between">
                                    <dt class="text-gray-600">Duty Fee</dt>
                                    <dd class="font-medium">
                                        {formatGYD(invoice.duty_fee || 0)}
                                    </dd>
                                </div>
                                <hr class="my-3" />
                                <div
                                    class="flex justify-between items-baseline"
                                >
                                    <dt
                                        class="text-sm font-semibold tracking-wide text-gray-700 uppercase"
                                    >
                                        Total Due
                                    </dt>
                                    <dd
                                        class="text-2xl font-bold text-pink-600"
                                    >
                                        {formatGYD(invoice.total_gyd || 0)}
                                    </dd>
                                </div>
                            </dl>
                        </div>

                        <div
                            class="bg-white rounded-lg shadow-sm p-6 space-y-4"
                        >
                            <h2 class="text-lg font-semibold text-gray-900">
                                Invoice PDF
                            </h2>
                            {
                                hasPdf ? (
                                    <p class="text-sm text-gray-600">
                                        Current file:
                                        <a
                                            href={pdfHref}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="text-primary hover:text-primary/80 underline ml-1"
                                        >
                                            View PDF
                                        </a>
                                    </p>
                                ) : (
                                    <p class="text-sm text-gray-600">
                                        No PDF is attached yet. After copying
                                        these details into your own template,
                                        upload the finished PDF here.
                                    </p>
                                )
                            }

                            <form
                                method="POST"
                                enctype="multipart/form-data"
                                class="space-y-3"
                            >
                                <input
                                    type="file"
                                    name="invoice_file"
                                    accept="application/pdf"
                                    class="block w-full text-sm text-gray-700 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20"
                                />
                                <button
                                    type="submit"
                                    class="btn-primary w-full"
                                >
                                    {
                                        invoice.invoice_file_url
                                            ? "Replace PDF"
                                            : "Upload PDF"
                                    }
                                </button>
                            </form>
                            {
                                hasPdf && (
                                    <form
                                        method="POST"
                                        action={`/api/admin/invoices/${id}/send-email`}
                                        class="mt-3"
                                    >
                                        <button
                                            type="submit"
                                            class="btn-secondary w-full"
                                        >
                                            Email Invoice to Customer
                                        </button>
                                    </form>
                                )
                            }
                        </div>
                    </div>
                </div>
            </div>
        </main>
    </div>
</BaseLayout>
